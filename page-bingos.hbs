{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}}
    <main class="site-main">

        <div class="page-bingo1-illustration" data-reveal>
            {{#if feature_image}}
            <img src="{{feature_image}}" alt="{{title}}">
            {{else}}
            <img src="{{asset 'illustrations/10.PNG'}}" alt="">
            {{/if}}
        </div>

        {{!-- 1. Hero Banner --}}
        <section class="resources-hero hero-minimal">
            <div class="container">
                <div class="resources-hero-content" data-reveal>
                    <h1 class="resources-hero-title">{{#if title}}{{title}}{{else}}Nature Bingos{{/if}}</h1>
                    <div class="resources-hero-subtitle">
                        {{!-- Original Static Description (Always There) --}}
                        <p>
                            We believe learning should be self-directed and fun, and Bingos are designed to do just
                            that.
                            Bingos encourage exploring the immediate nature around homes, neighborhoods, and schools –
                            promoting close observation, engaging multiple senses, and making learning a delightful game
                            for
                            both young students and adults. Use these diverse themes of Bingos to make your nature
                            exploration all the more exciting!
                        </p>

                        {{!-- Extra Ghost Content (Additive) --}}
                        {{#if content}}
                        <div class="ghost-content" style="margin-top: 20px;">
                            {{content}}
                        </div>
                        {{/if}}
                    </div>
                    <div class="hero-age-label">Ages 5+, Adults</div>
                </div>
            </div>
        </section>

        {{!-- 2. Resource Horizontal List --}}
        <section class="site-section">
            <div class="container">
                <div class="resource-horizontal-list">
                    {{!-- 1. Static Content (Always Visible) --}}
                    {{!-- Nature Bingo --}}
                    {{> "icons/resource-item"
                    title="Nature Bingo"
                    description="Step into the amazing world of local nature with our fun 'Nature Bingo' activity! From
                    insects on the wall, to flowers, fruits, and flying birds around you, use all your senses to explore
                    the nature around you and say BINGO!"
                    preview_image=(asset "bingos/Nature_Bingo.png")
                    download_url="#"
                    lang1="English"
                    lang2="ಕನ್ನಡ"
                    }}

                    {{!-- Hidden Housemates --}}
                    {{> "icons/resource-item"
                    title="Hidden Housemates"
                    description="Nature isn't confined to forests—they are all around us, even within our own four
                    walls! Explore the fascinating miniature ecosystems sharing your space."
                    preview_image=(asset "bingos/Hidden_Housemates.png")
                    download_url="/hidden-housemates/"
                    is_explore=true
                    }}

                    {{!-- Seasonal Bingo --}}
                    {{> "icons/resource-item"
                    title="Seasonal Bingo"
                    description="Seasons bring about remarkable transformations. Use these season-wise themed bingos to
                    discover the unique ecological responses that define every season."
                    preview_image=(asset "bingos/Rain_Bingo.png")
                    download_url="/seasonal-bingos/"
                    is_explore=true
                    }}

                    {{!-- Lotus Bingo --}}
                    {{> "icons/resource-item"
                    title="Lotus Bingo"
                    description="A Bingo designed to explore the world of wetlands in Kashmir, specifically in the
                    context of the Lotus plant which is integral to local culture."
                    preview_image=(asset "bingos/Lotus_Bingo.png")
                    download_url=(asset "files/Resources/Bingos/Lotus Bingo.pdf")
                    lang1="English"
                    }}

                    {{!-- Paddy Bingo --}}
                    {{> "icons/resource-item"
                    title="Paddy Bingo"
                    description="Paddy fields are rich, dynamic ecosystems. This bingo is designed for paddy fields to
                    guide playful observation and connect with the landscape."
                    preview_image=(asset "bingos/Rain_Bingo.png")
                    download_url=(asset "files/Resources/Bingos/Paddy Bingo/Paddy Bingo .pdf")
                    lang1="English"
                    lang1_url=(asset "files/Resources/Bingos/Paddy Bingo/Paddy Bingo .pdf")
                    lang2="ಕನ್ನಡ"
                    lang2_url=(asset "files/Resources/Bingos/Paddy Bingo/Kannada Paddy Bingo .pdf")
                    }}

                    {{!-- 2. Dynamic Content (Ghost) --}}
                    {{#get "posts" filter="tag:#hash-bingo" order="published_at desc" include="tags"}}
                    {{#foreach posts}}
                    {{> "icons/resource-item"
                    title=title
                    description=custom_excerpt
                    preview_image=feature_image
                    download_url=url
                    is_explore=true
                    }}
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Distribute the Nature Bingo sheets and explain the goal—to find at least three items in a
                            row or
                            a column (or all items, for a longer activity!) in their immediate surroundings. To add a
                            layer
                            of exploration, encourage students to use all your senses while exploring and looking for
                            the
                            items on the bingo. Once they find three in a row/column, they can shout out 'BINGO!' This
                            can
                            be a great individual exploration or a fun group challenge, fostering observation skills,
                            collaboration, and a connection to their local environment.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>What was easy to find? What was a challenge?</li>
                            <li>What new things did you notice in your surroundings?</li>
                            <li>What did you find that was not on the Bingo card?</li>
                            <li>How do these organisms interact with each other?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}