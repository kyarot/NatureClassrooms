{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main">
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero" style="height: 50vh; min-height: 400px;">
            <div class="resources-hero-bg" style="background-image: url('{{asset " carousel/2.jpg"}}');"></div>
            <div class="resources-hero-overlay"></div>
            <div class="resources-hero-content">
                <h1 class="resources-hero-title" data-reveal>Nature Bingos</h1>
                <p class="resources-hero-subtitle" data-reveal>
                    We believe learning should be self-directed and fun, and Bingos are designed to do just that. Bingos
                    encourage exploring the immediate nature around homes, neighborhoods, and schools – promoting close
                    observation and making learning a delightful game.
                </p>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                {{!-- 3. Resource Grid --}}
                <div class="resource-item-grid">
                    {{!-- Nature Bingo --}}
                    {{> "resource-item"
                    title="Nature Bingo"
                    description="Step into the amazing world of local nature! From insects on the wall to flowers and
                    flying
                    birds, use all your senses to explore and say BINGO!"
                    preview_image=(asset "carousel/1.jpg")
                    download_url="#"
                    lang1="English"
                    lang2="Kannada"
                    }}

                    {{!-- Hidden Housemates --}}
                    {{> "resource-item"
                    title="Hidden Housemates"
                    description="Nature isn't confined to forests—they are all around us, even within our own four
                    walls!
                    Explore the fascinating miniature ecosystems sharing your space."
                    preview_image=(asset "carousel/2.jpg")
                    download_url="/hiddenhousemates/"
                    lang1="English"
                    lang2="Hindi"
                    lang3="Kannada"
                    }}

                    {{!-- Seasonal Bingo --}}
                    {{> "resource-item"
                    title="Seasonal Bingo"
                    description="Seasons bring about remarkable transformations. Use these season-wise themed bingos to
                    discover the unique ecological responses that define every season."
                    preview_image=(asset "carousel/3.jpg")
                    download_url="/seasonalbingo/"
                    lang1="English"
                    lang2="Kannada"
                    }}

                    {{!-- Lotus Bingo --}}
                    {{> "resource-item"
                    title="Lotus Bingo"
                    description="A Bingo designed to explore the world of wetlands in Kashmir, specifically in the
                    context
                    of the Lotus plant which is integral to local culture."
                    preview_image=(asset "carousel/1.jpg")
                    download_url="#"
                    lang1="English"
                    }}

                    {{!-- Paddy Bingo --}}
                    {{> "resource-item"
                    title="Paddy Bingo"
                    description="Paddy fields are rich, dynamic ecosystems. This bingo is designed for paddy fields to
                    guide
                    playful observation and connect with the landscape."
                    preview_image=(asset "carousel/2.jpg")
                    download_url="#"
                    lang1="English"
                    lang2="Kannada"
                    }}
                </div>
            </div>
        </section>
        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <div class="educator-icon">
                            <i class="fas fa-chalkboard-teacher"></i>
                        </div>
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Distribute the Nature Bingo sheets and explain the goal—to find at least three items in a
                            row or
                            a column (or all items, for a longer activity!) in their immediate surroundings. To add a
                            layer
                            of exploration, encourage students to use all their senses while exploring and looking for
                            the
                            items on the bingo. Once they find three in a row/column, they can shout out 'BINGO!' This
                            can
                            be a great individual exploration or a fun group challenge, fostering observation skills,
                            collaboration, and a connection to their local environment.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>What was easy to find? What was a challenge?</li>
                            <li>What new things did you notice in your surroundings?</li>
                            <li>What did you find that was not on the Bingo card?</li>
                            <li>How do these organisms interact with each other?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });

            // Dynamic Navbar Color Switching
            const header = document.getElementById('siteHeader');
            const hero = document.querySelector('.resources-hero');
            const logoContainer = document.getElementById('floatingLogo');
            const logoImg = document.getElementById('floatingLogoImg');

            function updateNavbar() {
                if (!hero || !header) return;

                const scrollY = window.pageYOffset;
                const heroHeight = hero.offsetHeight;

                if (scrollY < heroHeight - 80) {
                    header.classList.remove('navbar-light');
                    header.classList.add('navbar-dark');
                    if (logoContainer) logoContainer.classList.remove('logo-dark');
                    if (logoImg && window.whiteLogo) logoImg.src = window.whiteLogo;
                } else {
                    header.classList.add('navbar-light');
                    header.classList.remove('navbar-dark');
                    if (logoContainer) logoContainer.classList.add('logo-dark');
                    if (logoImg && window.blackLogo) logoImg.src = window.blackLogo;
                }

                if (scrollY > 100) {
                    header.classList.add('navbar-scrolled');
                } else {
                    header.classList.remove('navbar-scrolled');
                }
            }

            window.addEventListener('scroll', updateNavbar, { passive: true });
            updateNavbar();
        });
    </script>
    {{/post}}