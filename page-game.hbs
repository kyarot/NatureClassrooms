{{!< default}} {{#post}} <div class="game-page">

    <!-- Hero Section -->
    <section class="game-hero">
        <h1>{{#if title}}{{title}}{{else}}There's Nothing There: Game{{/if}}</h1>
        <div class="game-hero-description">{{content}}</div>
    </section>

    <!-- Game Preview Section -->
    <section class="game-preview-section">
        <div class="game-preview-container">
            <div class="game-preview-image">
                <img src="{{#if feature_image}}{{feature_image}}{{else}}{{asset 'storybooks/storybooks.png'}}{{/if}}"
                    alt="{{title}}">
            </div>
        </div>
    </section>

    <!-- About the Game Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-game-about" limit="1"}}
    {{#foreach posts}}
    <section class="game-about-section">
        <div class="game-about-container">
            <div class="game-about-card">
                <div class="game-about-content resource-item-desc">
                    {{content}}
                </div>
                <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                    style="margin-top: 20px;">
                    <div class="dynamic-download-container" style="display: none;">
                        <div class="download-dropdown">
                            <button class="download-dropdown-btn">
                                <span>Download</span>
                                <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="dropdown-menu dynamic-menu"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    <!-- Download Instructions Section -->
    <section class="game-download-section">
        <div class="game-download-container">
            <h2 class="game-download-title">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                How to Download & Play
            </h2>
            <div class="game-steps">
                <div class="game-step">
                    <div class="game-step-number">1</div>
                    <div class="game-step-content">
                        <h3>Download</h3>
                        <p>Download the folder to your computer by clicking on the download button below.</p>
                    </div>
                </div>
                <div class="game-step-connector"></div>
                <div class="game-step">
                    <div class="game-step-number">2</div>
                    <div class="game-step-content">
                        <h3>Unzip & Open</h3>
                        <p>Once downloaded, unzip the folder, open it and click on the file named
                            <strong>Book_Game_Prototype.exe</strong>
                        </p>
                    </div>
                </div>
                <div class="game-step-connector"></div>
                <div class="game-step">
                    <div class="game-step-number">3</div>
                    <div class="game-step-content">
                        <h3>Play!</h3>
                        <p>This file will open the game. Enjoy exploring with Arali and her Amma!</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    </div>
    {{/post}}