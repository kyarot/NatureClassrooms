{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}
    {{#post}}

    <!-- Hero Section -->
    <section class="nm-hero">
        <h1>{{title}}</h1>
        <div class="nm-hero-content">
            {{content}}
        </div>
    </section>

    <!-- Section Header -->
    <div class="nm-section-header">
        <div class="nm-section-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                <line x1="9" y1="7" x2="15" y2="7"></line>
                <line x1="9" y1="11" x2="15" y2="11"></line>
            </svg>
            Resources
        </div>
        <div class="nm-section-line"></div>
    </div>

    <div class="nm-grid resource-item-grid-3-col">
        {{#get "posts" filter="tag:hash-nature-move" order="published_at desc" include="tags" formats="html"}}
        {{#foreach posts}}
        <div class="nm-card resource-item-card">
            <div class="nm-card-img">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
                <div class="nm-card-overlay">
                    <a href="{{url}}" class="nm-overlay-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Explore
                    </a>
                </div>
            </div>
            <div class="nm-card-content">
                <h3>{{title}}</h3>
                <div class="nm-card-desc resource-item-desc">{{{html}}}</div>
                <div class="nm-card-footer resource-item-footer" data-custom-link="{{url}}" data-parse-body="true">
                    {{!-- Dynamic Download Container --}}
                    <div class="dynamic-download-container" style="display: none; margin-bottom: 12px;">
                        <div class="download-dropdown">
                            <button class="download-dropdown-btn">
                                <span>Download</span>
                                <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="dropdown-menu dynamic-menu"></div>
                        </div>
                    </div>

                    <a href="{{url}}" class="nm-download-btn explore-btn">
                        Explore Resource
                    </a>
                </div>
            </div>
        </div>
        {{/foreach}}
        {{/get}}
    </div>

   

    {{/post}}