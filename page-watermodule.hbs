{{!< default}} {{#post}} <div class="water-module-page">

    <!-- Hero Section -->
    <section class="wm-hero">
        <h1>{{title}}</h1>
    </section>

    <!-- About Section -->
    <section class="wm-about-section">
        <div class="wm-about-card">
            <div class="wm-about-content">
                {{content}}
            </div>
        </div>
    </section>

    {{!-- Download Section (Always Visible) --}}
    <section class="wm-download-section">
        <div class="wm-download-card">
            <div class="wm-download-image">
                <img src="{{asset 'mod/Water Module - Explore Life in Water.png'}}"
                    alt="Water Module - Learning Module on Aquatic Ecosystems">
            </div>
            <div class="wm-download-info">
                <h3 class="wm-download-title">Download the Water Module</h3>
                <div class="wm-download-buttons">
                    <a href="{{asset 'files/Resources/Modules/Water Module - Explore Life in Water/Learning Module.pdf'}}"
                        class="wm-download-btn" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Learning Module
                    </a>
                    <a href="{{asset 'files/Resources/Modules/Water Module - Explore Life in Water/WaterModule_WithResources (1).pdf'}}"
                        class="wm-download-btn wm-download-btn-outline" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Module with Resources
                    </a>
                </div>
                <p class="wm-download-tagline">This learning module is an invitation to discover, develop and nurture a
                    wonderment and curiosity for water as an ecosystem that is teeming with amazing life forms that use
                    it in various ways!</p>
            </div>
        </div>
    </section>

    <!-- Explore More Section -->
    <section class="wm-explore-more">
        <a href="/modules/" class="wm-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Explore More Learning Modules
        </a>
    </section>

    </div>
    {{/post}}