{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main">
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero" style="text-align: left; justify-content: flex-start;">
            <div class="resources-hero-bg" style="background-image: url('{{asset "carousel/3.jpg"}}');"></div>
            <div class="resources-hero-overlay"></div>
            <div class="container" style="z-index: 3; position: relative; width: 100%;">
            <div class="resources-hero-content"style="margin-left: 0; padding-left: 0; text-align: left;">
                <h1 class="resources-hero-title" style="color: white;" data-reveal>Learning Modules</h1>
                <p class="resources-hero-subtitle" style="margin-left: 0;" data-reveal>
                    Our learning modules are designed to help you go beyond the textbook and explore the rich,
                    often-overlooked layers of the natural world through hands-on activities and engaging resources.
                </p>
            </div>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                {{!-- 3. Resource Grid --}}
                <div class="resource-item-grid">
                    {{!-- Water Module --}}
                    {{> "resource-item"
                    title="Water Module"
                    description="Water is an ecosystem that goes so much beyond our use. Explore the amazing life forms
                    that
                    use it in various ways, from puddles to rivers!"
                    preview_image=(asset "carousel/1.jpg")
                    download_url="/watermodule/"
                    lang1="English"
                    lang2="Kannada"
                    }}

                    {{!-- Nature Moves --}}
                    {{> "resource-item"
                    title="Nature Moves"
                    description="Nature Moves is a resource bank of movement-based activities exploring how everything
                    in
                    nature moves, from leaves to ants."
                    preview_image=(asset "carousel/2.jpg")
                    download_url="/naturemoves/"
                    lang1="English"
                    }}

                    {{!-- Nature Strokes --}}
                    {{> "resource-item"
                    title="Nature Strokes"
                    description="Nature Strokes is an Art and Nature handbook using art as a vibrant medium for learning
                    about nature and vice versa."
                    preview_image=(asset "carousel/3.jpg")
                    download_url="/naturestrokes/"
                    lang1="English"
                    }}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <div class="educator-icon">
                            <i class="fas fa-cubes"></i>
                        </div>
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Our learning modules are invitations to explore rich, often-overlooked layers of the natural
                            world.
                            Designed to achieves specific learning goals, each level incorporates stories, observation
                            charts,
                            and group activities that link with existing EVS textbooks. They are structured to nurture a
                            deep sense
                            of wonder for ecosystems that are often teeming with life we miss in our daily lives.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>How does this module help achieve our current curriculum goals?</li>
                            <li>Which activity sparked the most curiosity among the students?</li>
                            <li>How can we extend these lessons to our immediate school neighborhood?</li>
                            <li>What new perspectives did students gain about water or movement in nature?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });

            // Dynamic Navbar Color Switching
            const header = document.getElementById('siteHeader');
            const hero = document.querySelector('.resources-hero');
            const logoContainer = document.getElementById('floatingLogo');
            const logoImg = document.getElementById('floatingLogoImg');

            function updateNavbar() {
                if (!hero || !header) return;

                const scrollY = window.pageYOffset;
                const heroHeight = hero.offsetHeight;

                if (scrollY < heroHeight - 80) {
                    header.classList.remove('navbar-light');
                    header.classList.add('navbar-dark');
                    if (logoContainer) logoContainer.classList.remove('logo-dark');
                    if (logoImg && window.whiteLogo) logoImg.src = window.whiteLogo;
                } else {
                    header.classList.add('navbar-light');
                    header.classList.remove('navbar-dark');
                    if (logoContainer) logoContainer.classList.add('logo-dark');
                    if (logoImg && window.blackLogo) logoImg.src = window.blackLogo;
                }

                if (scrollY > 100) {
                    header.classList.add('navbar-scrolled');
                } else {
                    header.classList.remove('navbar-scrolled');
                }
            }

            window.addEventListener('scroll', updateNavbar, { passive: true });
            updateNavbar();
        });
    </script>
    {{/post}}