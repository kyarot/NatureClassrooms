{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}}
    <main class="site-main">
        <div class="page-modules-illustration" data-reveal>
            <img src="{{#if feature_image}}{{feature_image}}{{else}}{{asset 'illustrations/10.PNG'}}{{/if}}" alt="">
        </div>
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero hero-minimal">
            <div class="container">
                <div class="resources-hero-content" data-reveal>
                    <h1 class="resources-hero-title">{{#if title}}{{title}}{{else}}Learning Modules{{/if}}</h1>
                    <div class="resources-hero-subtitle">
                        {{#if content}}
                        {{content}}
                        {{else}}
                        <p>
                            Our learning modules are designed to help you go beyond the textbook and explore the rich,
                            often-overlooked layers of the natural world. Each module is an invitation to discover,
                            develop,
                            and nurture a deep sense of wonder through hands-on activities and engaging resources.
                        </p>
                        {{/if}}
                    </div>
                </div>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                <div class="resource-horizontal-list">
                    {{#get "posts" filter="tag:#hash-module" order="published_at desc" include="tags"}}
                    {{#foreach posts}}
                    {{> "icons/resource-item"
                    title=title
                    description=custom_excerpt
                    preview_image=feature_image
                    download_url=url
                    is_explore=true
                    }}
                    {{/foreach}}
                    {{else}}
                    {{!-- Fallback to original content --}}
                    {{!-- Water Module --}}
                    {{> "icons/resource-item"
                    title="Water Module - Explore Life in Water"
                    description="Water, as an ecosystem, goes so much beyond our use and interactions with it. Even a
                    little puddle of water after a rain that collects on your potholed road or in the crevice of a tree
                    trunk will attract birds, frogs, and dragonflies! This learning module is an invitation to discover,
                    develop, and nurture a wonderment and curiosity for water as an ecosystem that is teeming with
                    amazing life forms that use it in various ways!"
                    preview_image=(asset "modules/Water_Module.png")
                    download_url="/watermodule/"
                    is_explore=true
                    }}

                    {{!-- Nature Moves --}}
                    {{> "icons/resource-item"
                    title="Nature Moves"
                    description="Something we overlook in nature is how it moves, from Peepal leaves on a windy day to
                    the shuffle of antennae in an army of weaver ants. An exploration of the integration of movement and
                    nature education, Nature Moves is a resource bank of movement-based activities that educators can
                    choose from in their nature education and environmental studies classes."
                    preview_image=(asset "modules/Nature_Moves.png")
                    download_url="/naturemoves/"
                    is_explore=true
                    }}

                    {{!-- Nature Strokes --}}
                    {{> "icons/resource-item"
                    title="Nature Strokes"
                    description="The Nature Strokes module is an Art and Nature handbook filled with activities,
                    resources, and ideas that use art as a vibrant medium for learning about nature and, in turn,
                    learning about art through nature. Look out for updates from us as we release more units of this
                    module in various themes!"
                    preview_image=(asset "modules/Nature_Strokes.png")
                    download_url="/naturestrokes/"
                    is_explore=true
                    }}
                    {{/get}}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Our learning modules are invitations to explore rich, often-overlooked layers of the natural
                            world. Designed to achieves specific learning goals, each level incorporates stories,
                            observation
                            charts, and group activities that link with existing EVS textbooks. They are structured to
                            nurture a
                            deep sense of wonder for ecosystems that are often teeming with life we miss in our daily
                            lives.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>How does this module help achieve our current curriculum goals?</li>
                            <li>Which activity sparked the most curiosity among the students?</li>
                            <li>How can we extend these lessons to our immediate school neighborhood?</li>
                            <li>What new perspectives did students gain about water or movement in nature?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}