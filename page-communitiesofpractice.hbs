{{!< default}} {{#post}} <div class="cop-page">

    <!-- Hero Section -->
    <section class="cop-hero">
        <h1>{{title}}</h1>
        <p class="cop-hero-subtitle">{{custom_excerpt}}</p>
    </section>

    <!-- About Section -->
    <section class="cop-about-section">
        <div class="cop-about-card">
            <div class="cop-about-content">
                {{content}}
            </div>
        </div>
    </section>



    <!-- Back to Projects -->
    <section class="cop-explore-more">
        <a href="/" class="cop-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}