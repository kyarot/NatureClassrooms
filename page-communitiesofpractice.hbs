{{!< default}} {{#post}} <div class="cop-page">

    <!-- Hero Section -->
    <section class="cop-hero">
        <h1>{{title}}</h1>
        <div class="cop-hero-subtitle">{{content}}</div>
    </section>

    <!-- About Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-cop-about" limit="1"}}
    {{#foreach posts}}
    <section class="cop-about-section">
        <div class="cop-about-card">
            <div class="cop-about-content resource-item-desc">
                {{content}}
            </div>
            <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                style="margin-top: 20px;">
                <div class="dynamic-download-container" style="display: none;">
                    <div class="download-dropdown">
                        <button class="download-dropdown-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="dropdown-menu dynamic-menu"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}



    <!-- Back to Projects -->
    <section class="cop-explore-more">
        <a href="/" class="cop-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}