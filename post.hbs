{{!< default}} {{#post}} <div class="post-page site-section">
    <div class="container">
        <article class="{{post_class}} post-article">
            <header class="post-header">
                {{#if tags}}
                <div class="post-tags">
                    {{#foreach tags}}
                    <a href="{{url}}" class="post-tag-badge" {{#if
                        accent_color}}style="background-color: {{accent_color}};" {{/if}}>{{name}}</a>
                    {{/foreach}}
                </div>
                {{/if}}

                <h1 class="post-title">{{title}}</h1>

                <div class="post-meta-single">
                    <time datetime="{{date format=" YYYY-MM-DD"}}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        {{date format="MMMM D, YYYY"}}
                    </time>
                    <span class="reading-time">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        {{reading_time}}
                    </span>
                </div>

                {{#if feature_image}}
                <figure class="post-feature-image">
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{#if feature_image_caption}}
                    <figcaption>{{feature_image_caption}}</figcaption>
                    {{/if}}
                </figure>
                {{/if}}
            </header>

            <div class="post-body">
                <!-- Table of Contents Sidebar -->
                <aside class="toc-sidebar" id="tocSidebar">
                    <div class="toc-container">
                        <h4 class="toc-title">On this page</h4>
                        <nav class="toc-nav" id="tocNav" aria-label="Table of contents">
                            <!-- Generated by JavaScript -->
                        </nav>
                    </div>
                </aside>

                <!-- Post Content -->
                <section class="post-content">
                    {{content}}
                </section>
            </div>

            <!-- Share Section -->
            <div class="post-share">
                <span class="share-label">Share this post</span>
                <div class="share-buttons">
                    <a href="https://twitter.com/intent/tweet?text={{encode title}}&url={{url absolute=" true"}}"
                        class="share-btn share-twitter" target="_blank" rel="noopener" aria-label="Share on X">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                            fill="currentColor">
                            <path
                                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                        </svg>
                    </a>
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{url absolute=" true"}}"
                        class="share-btn share-facebook" target="_blank" rel="noopener" aria-label="Share on Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                            fill="currentColor">
                            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                        </svg>
                    </a>
                    <a href="https://wa.me/?text={{encode title}}%20{{url absolute=" true"}}"
                        class="share-btn share-whatsapp" target="_blank" rel="noopener" aria-label="Share on WhatsApp">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                            fill="currentColor">
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                        </svg>
                    </a>
                    <button class="share-btn share-copy" onclick="navigator.clipboard.writeText('{{url absolute="
                        true"}}').then(function(){this.classList.add('copied');setTimeout(function(){document.querySelector('.share-copy').classList.remove('copied')},2000)}.bind(this))"
                        aria-label="Copy link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Author Bio -->
            {{#primary_author}}
            <footer class="post-footer">
                <div class="author-card-single">
                    {{#if profile_image}}
                    <img src="{{profile_image}}" alt="{{name}}" class="author-avatar-single">
                    {{else}}
                    <div class="author-avatar-single author-avatar-fallback">
                        <span>{{name.[0]}}</span>
                    </div>
                    {{/if}}
                    <div class="author-info-single">
                        <h3><a href="{{url}}">{{name}}</a></h3>
                        {{#if bio}}
                        <p>{{bio}}</p>
                        {{/if}}
                    </div>
                </div>
            </footer>
            {{/primary_author}}
        </article>
    </div>
    </div>

    <script>
        (function () {
            document.addEventListener('DOMContentLoaded', function () {
                var content = document.querySelector('.post-content');
                var tocNav = document.getElementById('tocNav');
                var tocSidebar = document.getElementById('tocSidebar');

                if (!content || !tocNav || !tocSidebar) return;

                var headings = content.querySelectorAll('h2, h3');

                // Hide TOC if no headings
                if (headings.length === 0) {
                    tocSidebar.style.display = 'none';
                    return;
                }

                var tocList = document.createElement('ul');
                tocList.className = 'toc-list';

                headings.forEach(function (heading, index) {
                    // Generate ID if not present
                    if (!heading.id) {
                        var slug = heading.textContent
                            .toLowerCase()
                            .replace(/[^\w\s-]/g, '')
                            .replace(/\s+/g, '-')
                            .replace(/-+/g, '-')
                            .trim();
                        heading.id = slug + '-' + index;
                    }

                    var li = document.createElement('li');
                    li.className = 'toc-item toc-' + heading.tagName.toLowerCase();

                    var link = document.createElement('a');
                    link.href = '#' + heading.id;
                    link.textContent = heading.textContent;
                    link.className = 'toc-link';

                    // Smooth scroll on click
                    link.addEventListener('click', function (e) {
                        e.preventDefault();
                        var target = document.getElementById(heading.id);
                        if (target) {
                            var offset = 100;
                            var position = target.getBoundingClientRect().top + window.pageYOffset - offset;
                            window.scrollTo({
                                top: position,
                                behavior: 'smooth'
                            });
                            // Update URL hash without jumping
                            history.pushState(null, null, '#' + heading.id);
                        }
                    });

                    li.appendChild(link);
                    tocList.appendChild(li);
                });

                tocNav.appendChild(tocList);

                // Highlight active section on scroll
                var tocLinks = tocNav.querySelectorAll('.toc-link');

                function updateActiveLink() {
                    var fromTop = window.scrollY + 120;

                    headings.forEach(function (heading, index) {
                        var section = heading;
                        var nextHeading = headings[index + 1];
                        var sectionEnd = nextHeading ? nextHeading.offsetTop : document.body.scrollHeight;

                        if (section.offsetTop <= fromTop && sectionEnd > fromTop) {
                            tocLinks.forEach(function (link) {
                                link.classList.remove('is-active');
                            });
                            tocLinks[index].classList.add('is-active');
                        }
                    });
                }

                window.addEventListener('scroll', updateActiveLink);
                updateActiveLink();
            });
        })();
    </script>
    {{/post}}