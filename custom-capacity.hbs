{{!< default}} {{#post}} <div class="capacity-page">
    {{!-- Hero Section --}}
    <section class="capacity-hero">
        <div class="capacity-hero-bg" style="background-image: url('{{feature_image}}');"></div>
        <div class="capacity-hero-overlay"></div>
        <div class="capacity-hero-content">
            <h1>{{title}}</h1>
        </div>
    </section>

    {{#if content}}
    <section class="capacity-dynamic-content">
        <div class="container" style="padding: 100px 20px;">
            {{content}}
        </div>
    </section>
    {{/if}}

    {{!-- Intro Section --}}
    {{#get "posts" filter="tag:hash-sec-capacity-intro" limit="1"}}
    {{#foreach posts}}
    <section class="capacity-intro">
        <div class="capacity-intro-container">
            <h2>{{title}}</h2>
            {{content}}
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- Testimonial Section --}}
    {{#get "posts" filter="tag:hash-sec-capacity-testimonial" limit="1"}}
    {{#foreach posts}}
    <section class="capacity-testimonial">
        <div class="testimonial-container">
            <div class="testimonial-text">
                {{content}}
            </div>
            <div class="testimonial-author">
                — {{title}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- Who We Engage With --}}
    <section class="engagement-section">
        <div class="container">
            <h2 style="text-align: center; margin-bottom: 20px;"> Who Do We Engage With</h2>
            <div class="engagement-grid">
                {{#get "posts" limit="100" filter="tag:hash-card-capacity-engagement" include="tags,authors"
                order="published_at asc"}}
                {{#foreach posts}}
                <div class="engagement-card">
                    <div class="card-image">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image}}" alt="{{title}}">
                        {{/if}}
                    </div>
                    <div class="card-content">
                        <h3>{{title}}</h3>
                        {{content}}
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Collaborators Grid --}}
    <section class="collaborators-section">
        <div class="collaborators-container">
            <h2>Organisations we have collaborated with</h2>
            <div class="collaborators-list">
                {{#get "posts" limit="100" filter="tag:hash-card-capacity-collaborator" order="published_at asc"}}
                {{#foreach posts}}
                <span class="collaborator-tag">{{title}}</span>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Collaboration Callout --}}
    {{#get "posts" filter="tag:hash-sec-capacity-cta" limit="1"}}
    {{#foreach posts}}
    <section class="rc-collab-section">
        <div class="collab-box">
            <div class="collab-details">
                <h4>{{title}}</h4>
                {{content}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}
    </div>
    {{/post}}