{{!< default}} <div class="capacity-page">

    <!-- Hero Section -->
    <section class="capacity-hero">
        <div class="capacity-hero-bg"></div>
        <div class="capacity-hero-overlay"></div>
        <div class="capacity-hero-content">
            <h1>Capacity Building</h1>
            <p>Training & Workshops for Educators</p>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="capacity-intro">
        <div class="capacity-intro-container">
            <h2>Our Purpose</h2>
            <p>
                Our training workshops are contextually curated and range from a half-day session to an immersive
                four-day engagement.
                Through interactive discussions we explore different educational theories, practical tools, and
                pedagogical approaches with the teachers and educators.
            </p>
            <p>
                The goal is for the learners to adopt and adapt these within their own teaching-learning spaces and
                communities and to deepen their nature learning while weaving in the local-social-cultural contexts to
                which they belong.
            </p>
        </div>
    </section>

    <!-- Testimonial Section -->
    <section class="capacity-testimonial">
        <div class="testimonial-container">
            <div class="testimonial-text">
                "I teaching literature and earlier I felt unable to bring that connection. But after attending the
                workshop, I think I can instead use local stories and students will be able to easily relate to these
                stories."
            </div>
            <div class="testimonial-author">
                — An Educator's Experience
            </div>
        </div>
    </section>

    <!-- Who We Engage With -->
    <section class="engagement-section">
        <div class="container">
            <div class="engagement-grid">
                <!-- Teachers -->
                <div class="engagement-card">
                    <div class="card-image">
                        <img src="{{asset 'capacity/cap2.JPG'}}" alt="Teachers & Educators">
                    </div>
                    <div class="card-content">
                        <h3>Teachers & Educators</h3>
                        <p>
                            We design and curate immersive nature learning workshops for teachers and educator groups
                            from diverse teaching-learning spaces.
                            We guide them through lesson planning activities, giving them the firsthand experience.
                        </p>
                    </div>
                </div>

                <!-- Organisations -->
                <div class="engagement-card">
                    <div class="card-image">
                        <img src="{{asset 'capacity/cap3.JPG'}}" alt="Education Organisations">
                    </div>
                    <div class="card-content">
                        <h3>Education Organisations</h3>
                        <p>
                            We collaborate with education organizations and fellowships to integrate nature learning
                            into their existing programmes.
                            We guide their educators and trainers on how to effectively blend theory and practice.
                        </p>
                    </div>
                </div>

                <!-- Conservationists -->
                <div class="engagement-card">
                    <div class="card-image">
                        <img src="{{asset 'capacity/cap4.JPG'}}" alt="Conservation Scientists">
                    </div>
                    <div class="card-content">
                        <h3>Conservation Scientists</h3>
                        <p>
                            We design and facilitate sessions for conservation science organisations and students
                            introducing them to appropriate theories and practices from the field of education.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Collaborators Grid -->
    <section class="collaborators-section">
        <div class="collaborators-container">
            <h2>Organisations we have collaborated with</h2>
            <div class="collaborators-list">
                <span class="collaborator-tag">Fig Tree Learning Center</span>
                <span class="collaborator-tag">Wipro Foundation</span>
                <span class="collaborator-tag">Agastya International Foundation</span>
                <span class="collaborator-tag">Azim Premji Foundation</span>
                <span class="collaborator-tag">Center for Wildlife Studies</span>
                <span class="collaborator-tag">Let’s Be The Change</span>
                <span class="collaborator-tag">Bhoomi - Teach for Nature Fellowship</span>
                <span class="collaborator-tag">EarlyBird Programme</span>
                <span class="collaborator-tag">SeasonWatch Programme</span>
                <span class="collaborator-tag">Aripana Foundation</span>
                <span class="collaborator-tag">Punarchith</span>
                <span class="collaborator-tag">Parikrma Humanity Foundation</span>
                <span class="collaborator-tag">Nature Conservation Foundation</span>
                <span class="collaborator-tag">SCCS-Bengaluru</span>
