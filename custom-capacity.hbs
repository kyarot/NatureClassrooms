                <span class="collaborator-tag">Lal Family Foundation</span>
            </div>
        </div>
    </section>

    <!-- Collaboration Callout -->
    <section class="rc-collab-section">
        <div class="collab-box">

            <div class="collab-details">
                <h4>
                    If you want to be a part of our nature learning workshops for educators or want us to conduct a
                    workshop for your institution, or just want to know more, </h4>
                <p>Write to us at <a href="mailto:info@natureclassrooms.in">info@natureclassrooms.in</a></p>
            </div>
        </div>
    </section>

    </div>
    {{/post}}