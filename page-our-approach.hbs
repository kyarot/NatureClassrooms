{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    <link rel="stylesheet" href="{{asset 'css/ourapproach.css'}}">
    {{/contentFor}}

    <main class="site-main">
        {{#post}}
        {{!-- 1. Hero Section --}}
        <section class="approach-hero">
            <div class="approach-hero-bg"
                style="background-image: url('{{#if feature_image}}{{feature_image}}{{else}}{{asset "
                ourapproach/our1.jpg"}}{{/if}}');"></div>
            <div class="approach-hero-overlay"></div>
            <div class="approach-hero-content">
                <h1 class="approach-hero-title" data-reveal>{{title}}</h1>
                <div class="approach-hero-description" data-reveal>
                    {{content}}
                </div>
            </div>

            <div class="fog-separator">
                <div class="fog-blur"></div>
            </div>
        </section>

        {{!-- 2. Pillars Section --}}
        <section class="approach-section pillar-section" id="pedagogy">
            <div class="container">
                <h2 class="approach-section-title text-center" style="text-align: center; margin-bottom: 60px;">The
                    Pillars of Our Program</h2>
                <div class="pillar-grid">
                    {{#get "posts" filter="tag:hash-sec-approach-pillars" order="published_at asc" include="tags"
                    formats="html"}}
                    {{#foreach posts}}
                    <div class="pillar-card resource-item-card" data-reveal>
                        <div class="pillar-image">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}">
                            {{/if}}
                        </div>
                        <div class="pillar-content-wrapper js-content-box">
                            <h3 class="pillar-title">{{title}}</h3>
                            <div class="pillar-description resource-item-desc">
                                {{{html}}}
                            </div>
                            <div class="resource-item-footer"
                                data-custom-link="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                                data-parse-body="true">
                                <div class="dynamic-download-container" style="display: none;">
                                    <div class="download-dropdown">
                                        <button class="download-dropdown-btn">
                                            <span>Download</span>
                                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                                stroke-linejoin="round">
                                                <polyline points="6 9 12 15 18 9"></polyline>
                                            </svg>
                                        </button>
                                        <div class="dropdown-menu dynamic-menu"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </section>

        {{!-- 3. Nature in Action (Gallery) --}}
        {{#get "posts" filter="tag:hash-sec-approach-action" limit="1"}}
        {{#foreach posts}}
        <section class="approach-gallery approach-section">
            <div class="container">
                <h2 class="approach-section-title text-center" style="text-align: center; margin-bottom: 40px;">
                    {{title}}</h2>
                {{!-- Raw content for JS parsing --}}
                <div class="js-gallery-raw-content" style="display: none;">{{content}}</div>
                <div class="gallery-grid js-gallery-grid">
                    {{!-- Populated via JS --}}
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        {{!-- 4. Nature Learning Checklist --}}
        {{#get "posts" filter="tag:hash-sec-approach-checklist" limit="2"}}
        {{#foreach posts}}
        <section class="checklist-section approach-section">
            <div class="container">
                <h2 class="approach-section-title text-center" style="margin-bottom: 48px;">{{title}}</h2>
                <div class="js-checklist-box text-center" style="color: var(--text-secondary);">
                    {{!-- Hidden container for parsing --}}
                    <div class="resource-item-desc" style="display: none;">
                        {{content}}
                    </div>
                    {{!-- Container for generated buttons --}}
                    <div class="checklist-buttons-container"></div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        {{!-- 5. Recommended Reading --}}
        {{#get "posts" filter="tag:hash-sec-approach-reading" limit="1"}}
        {{#foreach posts}}
        <section class="approach-cta approach-section">
            <div class="container">
                <div class="cta-content js-reading-box" data-reveal>
                    <h2 class="cta-title">{{title}}</h2>
                    <div class="cta-description"
                        style="font-size: 1.2rem; margin-bottom: 40px; color: var(--text-secondary);">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        {{/post}}
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 1. Nature in Action (Gallery Parsing)
            const rawContentContainer = document.querySelector('.js-gallery-raw-content');
            const galleryGrid = document.querySelector('.js-gallery-grid');
            if (rawContentContainer && galleryGrid) {
                const images = rawContentContainer.querySelectorAll('img');
                let html = '';
                images.forEach(img => {
                    html += `
                        <div class="gallery-item" data-reveal>
                            <img src="${img.src}" alt="${img.alt || 'Nature in Action'}" class="gallery-img">
                        </div>`;
                });
                galleryGrid.innerHTML = html;
            }

            // 2. Checklist File Parser (finds file cards/links in .resource-item-desc)
            const checklistBoxes = document.querySelectorAll('.js-checklist-box');
            checklistBoxes.forEach(box => {
                const descContainer = box.querySelector('.resource-item-desc');
                const btnContainer = box.querySelector('.checklist-buttons-container');
                if (!descContainer || !btnContainer) return;

                const links = descContainer.querySelectorAll('a');
                links.forEach(link => {
                    let label = link.textContent.trim();
                    const fileCard = link.closest('.kg-file-card');

                    if (fileCard) {
                        const titleEl = fileCard.querySelector('.kg-file-card-title');
                        if (titleEl) label = titleEl.textContent.trim();
                        fileCard.remove();
                    } else {
                        link.remove();
                    }

                    if (label && link.href) {
                        const a = document.createElement('a');
                        a.href = link.href;
                        a.className = 'checklist-btn';
                        a.setAttribute('download', '');
                        a.textContent = label;
                        btnContainer.appendChild(a);
                    }
                });
            });

            // 3. Scroll Reveal Initialization
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        // For gallery items that might be added dynamically
                        if (entry.target.classList.contains('gallery-item')) {
                            entry.target.style.opacity = '1';
                            entry.target.style.transform = 'translateY(0)';
                        }
                    }
                });
            }, observerOptions);

            // Observe existing and newly added elements
            function observeElements() {
                document.querySelectorAll('[data-reveal]').forEach(el => {
                    observer.observe(el);
                });
            }

            observeElements();
            // Re-run for dynamic gallery items
            setTimeout(observeElements, 500);
        });
    </script>

    <style>
        /* Inline styles for components within the page context */
        .process-steps {
            max-width: 900px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .process-step {
            display: flex;
            gap: 32px;
            align-items: flex-start;
            padding: 40px;
            background: #ffffff;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            border: 1px solid var(--border-light);
        }

        .process-step:hover {
            transform: translateX(10px);
            box-shadow: var(--shadow-lg);
            border-color: var(--color-primary);
        }

        .step-number {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 900;
            color: rgba(74, 124, 89, 0.15);
            line-height: 1;
        }

        .step-content h3 {
            margin-bottom: 12px;
            color: var(--color-primary);
            font-size: 1.75rem;
        }

        .stats-mini {
            display: flex;
            gap: 40px;
            margin-top: 32px;
            padding-top: 32px;
            border-top: 1px solid var(--border-light);
        }

        .stat-item {
            display: flex;
            flex-direction: column;
        }

        .stat-num {
            font-size: 2rem;
            font-weight: 800;
            color: var(--color-primary);
            line-height: 1.2;
        }

        .stat-label {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            font-weight: 600;
        }

        .elaborate-links a {
            text-decoration: none;
            transition: opacity 0.3s;
        }

        .elaborate-links a:hover {
            opacity: 1 !important;
            text-decoration: underline;
        }

        .text-center {
            text-align: center;
        }

        @media (max-width: 768px) {
            .process-step {
                flex-direction: column;
                gap: 20px;
                padding: 30px;
            }

            .step-number {
                font-size: 2.5rem;
            }

            .stats-mini {
                gap: 24px;
            }
        }
    </style>