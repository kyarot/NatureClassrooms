{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/ourapproach.css'}}">
    {{/contentFor}}

    <main class="site-main">
        {{#post}}
        <div class="page-approach-illustration" data-reveal>
            <img src="{{asset 'illustrations/28.PNG'}}" alt="">
        </div>

        {{!-- 1. Hero Section --}}
        <section class="approach-hero">
            <div class="approach-hero-bg" style="background-image: url('{{asset "carousel/1.jpg"}}');"></div>
            <div class="approach-hero-overlay"></div>
            <div class="approach-hero-content">
                <span class="approach-hero-label" data-reveal>Cultivating Wonder</span>
                <h1 class="approach-hero-title" data-reveal>Our Approach</h1>
                <p class="approach-hero-description" data-reveal>
                    In a world where nature often feels distant, we bridge the gap through a pedagogy of wonder,
                    love, and lasting emotional connection with the natural world around us.
                </p>
            </div>

            {{!-- 2. Fog / Cloud Section Separator --}}
            <div class="fog-separator">
                <div class="fog-blur"></div>
            </div>
        </section>

        {{!-- 3. Philosophy Section (Alternating) --}}
        <section class="approach-section approach-overview" id="philosophy">
            <div class="container">
                <div class="approach-grid">
                    <div class="approach-content-block" data-reveal>
                        <span class="approach-section-subtitle">Our Philosophy</span>
                        <h2 class="approach-section-title">A Living Journey</h2>
                        <div class="approach-section-text">
                            <p>
                                Our approach is not static; it is a dynamic and collaborative journey informed by deep
                                research and real-world experiences. We engage with teachers, educators, and children
                                across
                                diverse geographies to understand the pulse of nature learning.
                            </p>
                            <p>
                                By correlating school curricula with the natural world, we transform abstract concepts
                                into experiential adventures that resonate with the heart and mind.
                            </p>
                        </div>
                    </div>
                    <div class="approach-image-container" data-reveal>
                        <img src="{{asset "carousel/2.jpg"}}" alt="Children exploring nature">
                    </div>
                </div>
            </div>
        </section>

        {{!-- 4. Research Section (Alternating) --}}
        <section class="approach-section" id="research">
            <div class="container">
                <div class="approach-grid alternate">
                    <div class="approach-content-block" data-reveal>
                        <span class="approach-section-subtitle">Evidence Based</span>
                        <h2 class="approach-section-title">Grounded in Research</h2>
                        <div class="approach-section-text">
                            <p>
                                Our Nature Learning Framework is built on hours of classroom observations, reflections,
                                and meaningful conversations with educators who are as passionate as we are about
                                reconnecting children with the earth.
                            </p>
                            <div class="stats-mini">
                                <div class="stat-item">
                                    <span class="stat-num">100+</span>
                                    <span class="stat-label">Workshops</span>
                                </div>
                                <div class="stat-item">
                                    <span class="stat-num">15+</span>
                                    <span class="stat-label">States</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="approach-image-container" data-reveal>
                        <img src="{{asset "carousel/3.jpg"}}" alt="Researcher in nature">
                    </div>
                </div>
            </div>
        </section>

