        {{!-- 7. Action Checklist Section --}}
        <section class="checklist-section approach-section">
            <div class="container">
                <h2 class="approach-section-title text-center" style="margin-bottom: 48px;">Pedagogy in Action</h2>
                <p class="text-center"
