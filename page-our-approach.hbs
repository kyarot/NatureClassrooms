            <div class="container">
                <h2 class="approach-section-title text-center" style="text-align: center; margin-bottom: 60px;">The
                    Pillars
                    of Our Program</h2>
                <div class="pillar-grid">
                    {{!-- Pillar 1: Pedagogy --}}
                    <div class="pillar-card" data-reveal>
                        <div class="pillar-image">
                            <img src="{{asset "fourarms/CapacityBuilding.JPG"}}" alt="Capacity Building & Training">
                        </div>
                        <div class="pillar-content-wrapper">
                            <h3 class="pillar-title">Nature Classrooms Pedagogy</h3>
                            <p class="pillar-description">
                                A dynamic, inclusive, and collaborative approach to planning nature learning
                                engagements.
                                It aims to develop a deep physical and emotional connection to the natural world.
                            </p>
                            <a href="https://www.natureclassrooms.org/_files/ugd/1dc466_b2c4f0bc82734afbafe657c177c1a1d3.pdf"
                                class="download-btn" target="_blank">Download Pedagogy <svg width="18" height="18"
                                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"></path>
                                    <polyline points="7 10 12 15 17 10"></polyline>
                                    <line x1="12" y1="15" x2="12" y2="3"></line>
                                </svg></a>
                        </div>
                    </div>

                    {{!-- Pillar 2: Framework --}}
                    <div class="pillar-card" data-reveal>
                        <div class="pillar-image">
                            <img src="{{asset "fourarms/Research.JPG"}}" alt="Research & Framework">
                        </div>
                        <div class="pillar-content-wrapper">
                            <h3 class="pillar-title">Nature Learning Framework</h3>
                            <p class="pillar-description">
                                Our comprehensive guide for educators in selecting, designing, and developing
                                age-appropriate resources and session plans for impactful nature education.
                            </p>
                            <a href="https://www.natureclassrooms.org/_files/ugd/1dc466_77e9664c22ea4220b94b23a27d56645b.pdf"
                                class="download-btn" target="_blank">Download Framework <svg width="18" height="18"
                                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"></path>
                                    <polyline points="7 10 12 15 17 10"></polyline>
                                    <line x1="12" y1="15" x2="12" y2="3"></line>
                                </svg></a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {{!-- 6. Visual Engagement Section --}}
