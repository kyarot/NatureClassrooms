            <div class="container">
                <h2 class="approach-section-title text-center" style="text-align: center; margin-bottom: 40px;">Nature
                    in
                    Action</h2>
                <div class="gallery-grid">
                    <div class="gallery-item" data-reveal>
                        <img src="{{asset "carousel/1.jpg"}}" alt="Nature Classroom Activity" class="gallery-img">
                    </div>
                    <div class="gallery-item" data-reveal>
                        <img src="{{asset "carousel/2.jpg"}}" alt="Children exploring nature" class="gallery-img">
                    </div>
                    <div class="gallery-item" data-reveal>
                        <img src="{{asset "carousel/3.jpg"}}" alt="Nature observation" class="gallery-img">
                    </div>
                    <div class="gallery-item" data-reveal>
                        <img src="{{asset "carousel/1.jpg"}}" alt="Outdoor learning" class="gallery-img">
                    </div>
