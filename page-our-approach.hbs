                <div style="margin-top: 80px; text-align: center;" data-reveal>
                    <p style="margin-bottom: 24px; font-weight: 600;">Want a more elaborate version with examples and
                        deeper
                        questions?</p>
                    <div class="elaborate-links"
                        style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
                        <a href="https://www.natureclassrooms.org/_files/ugd/9fa2a3_05a37ffe832e4576b085daa13b0c83cf.pdf"
                            class="checklist-btn"
                            style="background: transparent; border: 1px solid var(--color-primary); color: var(--color-primary) !important;"
                            target="_blank">English Guide</a>
                        <a href="https://www.natureclassrooms.org/_files/ugd/9fa2a3_8b044e1feeb64e03bd3b96aec2ec02a1.pdf"
                            class="checklist-btn"
                            style="background: transparent; border: 1px solid var(--color-primary); color: var(--color-primary) !important;"
                            target="_blank">Kannada Guide</a>
                        <a href="https://www.natureclassrooms.org/_files/ugd/9fa2a3_eae39475a56745fe9fa7d912a5d7ad3f.pdf"
                            class="checklist-btn"
                            style="background: transparent; border: 1px solid var(--color-primary); color: var(--color-primary) !important;"
                            target="_blank">Hindi Guide</a>
                    </div>
                </div>
            </div>
        </section>

        {{!-- 8. Process Section --}}
        <section class="process-section approach-section">
            <div class="container">
                <h2 class="approach-section-title text-center" style="text-align: center; margin-bottom: 60px;">Our
                    Process
                </h2>
                <div class="process-steps">
                    <div class="process-step" data-reveal>
                        <div class="step-number">01</div>
                        <div class="step-content">
                            <h3>Observe & Listen</h3>
                            <p>We start in the classroom, observing interactions and listening to the needs of both
                                teachers
                                and students.</p>
                        </div>
                    </div>
                    <div class="process-step" data-reveal>
                        <div class="step-number">02</div>
                        <div class="step-content">
                            <h3>Collaborate & Design</h3>
                            <p>Working closely with experienced educators, we co-create resources that are
                                age-appropriate
                                and curriculum-aligned.</p>
                        </div>
                    </div>
                    <div class="process-step" data-reveal>
                        <div class="step-number">03</div>
                        <div class="step-content">
                            <h3>Implement & Reflect</h3>
                            <p>Resources are tested in real environments, followed by a cycle of reflection and
                                continuous
                                improvement.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {{!-- 9. CTA Section --}}
        <section class="approach-cta approach-section">
            <div class="container">
                <div class="cta-content" data-reveal>
                    <h2 class="cta-title">Recommended Readings</h2>
                    <p class="cta-description"
                        style="font-size: 1.2rem; margin-bottom: 40px; color: var(--text-secondary);">
                        Discover curated readings, opinion pieces, and educational articles to deepen your understanding
                        of nature education.
                    </p>
                    <a href="/readings" class="cta-btn">View Recommended Readings</a>
                </div>
            </div>
        </section>

        {{/post}}
    </main>

    {{!-- Scroll Reveal & Navbar Switching Script --}}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal Initialization
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>

    <style>
        /* Inline styles for components within the page context */
        .process-steps {
            max-width: 900px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .process-step {
            display: flex;
            gap: 32px;
            align-items: flex-start;
            padding: 40px;
            background: #ffffff;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            transition: var(--transition);
            border: 1px solid var(--border-light);
        }

        .process-step:hover {
            transform: translateX(10px);
            box-shadow: var(--shadow-lg);
            border-color: var(--color-primary);
        }

        .step-number {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 900;
            color: rgba(74, 124, 89, 0.15);
            line-height: 1;
        }

        .step-content h3 {
            margin-bottom: 12px;
            color: var(--color-primary);
            font-size: 1.75rem;
        }

        .stats-mini {
            display: flex;
            gap: 40px;
            margin-top: 32px;
            padding-top: 32px;
            border-top: 1px solid var(--border-light);
        }

        .stat-item {
            display: flex;
            flex-direction: column;
        }

        .stat-num {
            font-size: 2rem;
            font-weight: 800;
            color: var(--color-primary);
            line-height: 1.2;
        }

        .stat-label {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            font-weight: 600;
        }

        .elaborate-links a {
            text-decoration: none;
            transition: opacity 0.3s;
        }

        .elaborate-links a:hover {
            opacity: 1 !important;
            text-decoration: underline;
        }

        .text-center {
            text-align: center;
        }

        @media (max-width: 768px) {
            .process-step {
                flex-direction: column;
                gap: 20px;
                padding: 30px;
            }

            .step-number {
                font-size: 2.5rem;
            }

            .stats-mini {
                gap: 24px;
            }
        }
    </style>