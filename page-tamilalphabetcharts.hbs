{{!< default}} {{#post}} <div class="tamil-alphabet-page">

    <!-- Hero Section -->
    <section class="ta-hero">
        <h1>{{#if title}}{{title}}{{else}}Tamil Alphabet Chart{{/if}}</h1>
        <div class="ta-hero-content">
            <p>Walk into any bookstore and you'll find alphabet charts filled with giraffes, penguins, and macaws. But
                what about all of nature that is right around us? This chart brings together the plants and animals of
                Tamil Nadu, from dugongs to Indrella snails, fungi, odonates, wasps, and wildflowers, all through the
                Tamil alphabet.</p>

            {{#if content}}
            <div class="ghost-content" style="margin-top: 2rem;">
                {{content}}
            </div>
            {{/if}}
        </div>
    </section>

    <!-- Section Header -->
    <div class="ta-section-header">
        <div class="ta-section-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                <line x1="9" y1="7" x2="15" y2="7"></line>
                <line x1="9" y1="11" x2="15" y2="11"></line>
            </svg>
            Resources
        </div>
        <div class="ta-section-line"></div>
    </div>

    <!-- Resource Grid -->
    <div class="ta-grid">
        {{#get "posts" filter="tag:#hash-tamil-alphabet" order="published_at desc" include="tags"}}
        {{#foreach posts}}
        <div class="ta-card">
            <div class="ta-card-img">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
                <div class="ta-card-overlay">
                    <a href="{{url}}" class="ta-overlay-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Explore
                    </a>
                </div>
            </div>
            <div class="ta-card-content">
                <h3>{{title}}</h3>
                <p class="ta-card-desc">{{custom_excerpt}}</p>
                <div class="ta-card-footer">
                    <a href="{{url}}" class="ta-download-btn">
                        Explore Resource
                    </a>
                </div>
            </div>
        </div>
        {{/foreach}}
        {{/get}}

        {{!-- Original Static Content (Always Visible) --}}
        <!-- Tamil Alphabet Chart -->
        <div class="ta-card">
            <div class="ta-card-img">
                <img src="{{asset 'ta/Tamil Alphabet Chart.png'}}" alt="Tamil Alphabet Chart">
                <div class="ta-card-overlay">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Tamil Alphabet Chart/Tamil Alphabet Chart.pdf'}}"
                        class="ta-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="ta-card-content">
                <h3>Tamil Alphabet Chart</h3>
                <p class="ta-card-desc">The complete Tamil alphabet chart featuring the rich biodiversity of Tamil Nadu.
                </p>
                <div class="ta-card-footer">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Tamil Alphabet Chart/Tamil Alphabet Chart.pdf'}}"
