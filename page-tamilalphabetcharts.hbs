{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}
    {{#post}}
    <div class="tamil-alphabet-page">

        <!-- Hero Section -->
        {{#get "posts" filter="tag:hash-sec-tamil-hero" limit="1"}}
        {{#foreach posts}}
        <section class="ta-hero">
            <h1>{{#if title}}{{title}}{{else}}Tamil Alphabet Chart{{/if}}</h1>
            <div class="ta-hero-content">
                {{#if content}}
                <div class="ghost-content">
                    {{content}}
                </div>
                {{else}}
                <p>Walk into any bookstore and you'll find alphabet charts filled with giraffes, penguins, and macaws.
                    But
                    what about all of nature that is right around us? This chart brings together the plants and animals
                    of
                    Tamil Nadu, from dugongs to Indrella snails, fungi, odonates, wasps, and wildflowers, all through
                    the
                    Tamil alphabet.</p>
                {{/if}}
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        <!-- Section Header -->
        <div class="ta-section-header">
            <div class="ta-section-title">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    <line x1="9" y1="7" x2="15" y2="7"></line>
                    <line x1="9" y1="11" x2="15" y2="11"></line>
                </svg>
                Resources
            </div>
            <div class="ta-section-line"></div>
        </div>

        <!-- Resource Grid -->
        <div class="ta-grid">
            {{#get "posts" filter="tag:hash-hash-tamil-alphabet" order="published_at asc" include="tags"}}
            {{#foreach posts}}
            <div class="ta-card">
                <div class="ta-card-img">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{/if}}
                    <div class="ta-card-overlay">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="ta-overlay-link">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="7 10 12 15 17 10"></polyline>
                                <line x1="12" y1="15" x2="12" y2="3"></line>
                            </svg>
                            Explore
                        </a>
                    </div>
                </div>
                <div class="ta-card-content">
                    <h3>{{title}}</h3>
                    <p class="ta-card-desc">{{custom_excerpt}}</p>
                    <div class="ta-card-footer resource-item-footer" data-custom-link="{{meta_description}}">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="ta-download-btn explore-btn">
                            Explore Resource
                        </a>
                        <div class="dynamic-download-container" style="display: none;">
                            <div class="download-dropdown">
                                <button class="download-dropdown-btn">
                                    <span>Download</span>
                                    <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </button>
                                <div class="dropdown-menu dynamic-menu">
                                    <!-- Filled via JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </div>

        {{#get "posts" filter="tag:hash-sec-tamil-video" limit="1"}}
        {{#foreach posts}}
        <section class="ta-video-section">
            <div class="container">
                <div class="ta-video-card">
                    <div class="ta-video-header">
                        <div class="ta-video-icon">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M23 7l-7 5 7 5V7z"></path>
                                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                            </svg>
                        </div>
                        <h2 class="ta-video-title">{{title}}</h2>
                    </div>
                    <div class="ta-video-content">
                        {{custom_excerpt}}
                    </div>
                    <div class="ta-video-wrapper">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        <!-- Explore More Section -->
        <section class="ta-explore-more">
            <a href="/alphabet-charts/" class="ta-explore-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Explore More Alphabet Charts
            </a>
        </section>

    </div>
    {{/post}}