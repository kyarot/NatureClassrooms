{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main">
        <div class="page-neem-illustration" data-reveal>
            <img src="{{asset 'illustrations/neem_fruit.png'}}" alt="">
        </div>
        <div class="page-anchor-bottom-illustration" data-reveal>
            <img src="{{asset 'illustrations/13_3289.PNG'}}" alt="">
        </div>
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero" style="text-align: left; justify-content: flex-start;">
            <div class="resources-hero-bg" style="background-image: url('{{asset "carousel/1.jpg"}}');"></div>
            <div class="resources-hero-overlay"></div>
            <div class="container" style="z-index: 3; position: relative; width: 100%;">
                <div class="resources-hero-content" style="margin-left: 0; padding-left: 0; text-align: left;">
                    <h1 class="resources-hero-title" style="color: white;" data-reveal>Anchor Charts</h1>
                    <p class="resources-hero-subtitle" style="margin-left: 0;" data-reveal>
                       
Anchor charts are a fun way to learn actively or passively! These anchor charts are perfect for visually connecting things- like how a tiny insect relies on a specific plant—and understanding behaviors, interactions, and phenomena around us, making it simple to start conversations and get curious about the living world around us.
                    </p>
                </div>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                {{!-- 3. Resource Grid --}}
                <div class="resource-item-grid">
                    {{!-- Plant Posters --}}
                    {{> "resource-item"
                    title="Plant Posters"
                    description="Plants right outside our doors are hubs for ecological interactions like shelter, food,
                    pollination, and seed dispersal - revealing a dynamic miniature ecosystem in every leaf and branch."
                    preview_image=(asset "carousel/2.jpg")
                    download_url="/plantposter/"
                    lang1="English"
                    lang2="Hindi"
                    lang3="Tamil"
                    }}

                    {{!-- Behaviour Tales --}}
                    {{> "resource-item"
                    title="Behaviour Tales"
                    description="Like how we humans groom and keep ourselves clean, animals too have fascinating ways in
                    which they do these essential behaviours and adaptations!"
                    preview_image=(asset "carousel/3.jpg")
                    download_url="/behaviortales/"
                    lang1="English"
                    lang2="Hindi"
                    lang3="Kannada"
                    }}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <div class="educator-icon">
                            <i class="fas fa-project-diagram"></i>
                        </div>
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Anchor charts are a powerful tool for visually connecting behaviors, interactions, and
                            natural
                            phenomena.
                            They help students understand complex ecological relationships—like how an insect relies on
                            a
                            specific
                            plant—making it simple to start conversations and spark curiosity about the living world.
                            Use
                            them to
                            supplement textbook chapters with real-world examples.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>Why do animals need to keep clean or groom themselves?</li>
                            <li>How does the interaction on this chart help both species?</li>
                            <li>What other animal behaviors have you observed in domestic pets?</li>
                            <li>Can you find a real-life example of this interaction outdoors?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}