{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main">
        <div class="page-neem-illustration" data-reveal>
            <img src="{{asset 'illustrations/neem_fruit.png'}}" alt="">
        </div>
        <div class="page-anchor-bottom-illustration" data-reveal>
            {{#if access}}
            {{!-- Fallback or secondary illustration can go here if needed --}}
            {{/if}}
        </div>
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero hero-minimal">
            <div class="container">
                <div class="resources-hero-content" data-reveal>
                    <h1 class="resources-hero-title">{{#if title}}{{title}}{{else}}Anchor Charts{{/if}}</h1>
                    <div class="resources-hero-subtitle">
                        {{!-- Original Static Description (Always There) --}}
                        <p>
                            Anchor charts are a fun way to learn actively or passively! These anchor charts are perfect
                            for
                            visually connecting things- like how a tiny insect relies on a specific plant—and
                            understanding
                            behaviors, interactions, and phenomena around us, making it simple to start conversations
                            and
                            get curious about the living world around us.
                        </p>

                        {{!-- Extra Ghost Content (Additive) --}}
                        {{#if content}}
                        <div class="ghost-content" style="margin-top: 20px;">
                            {{content}}
                        </div>
                        {{/if}}
                    </div>
                </div>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                {{!-- 3. Resource Grid --}}
                <div class="resource-horizontal-list">
                    {{!-- 1. Static Content (Always Visible) --}}
                    {{> "icons/resource-item"
                    title="Plant Posters"
                    description="Plants right outside our doors are hubs for ecological interactions like shelter, food,
                    pollination, and seed dispersal - revealing a dynamic miniature ecosystem in every leaf and branch.
                    These plant posters offer a close-up, dynamic view of a single plant, highlighting its various parts
                    and the fascinating interactions it has with the most common animals, birds, and insects that use
                    them."
                    preview_image=(asset "anchor/Plant_Poster.png")
                    download_url="/plantposter/"
                    is_explore=true
                    }}

                    {{> "icons/resource-item"
                    title="Behaviour Tales"
                    description="Like how we humans groom and keep ourselves clean, animals too have fascinating ways in
                    which they do these essential behaviours and adaptations! This resource was made to supplement
                    primary school chapters on human cleaning habits and delves into the amazing world of animal
                    hygiene, exploring how animals employ unique strategies to stay clean."
                    preview_image=(asset "anchor/Behaviour_tales.png")
                    download_url="/behaviortales/"
                    is_explore=true
                    }}

                    {{!-- 2. Dynamic Content (Ghost) --}}
                    {{#get "posts" filter="tag:#hash-anchor-chart" order="published_at desc" include="tags"}}
                    {{#foreach posts}}
                    {{> "icons/resource-item"
                    title=title
                    description=custom_excerpt
                    preview_image=feature_image
                    download_url=url
                    is_explore=true
                    }}
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">

                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            Anchor charts are a powerful tool for visually connecting behaviors, interactions, and
                            natural
                            phenomena.
                            They help students understand complex ecological relationships—like how an insect relies on
                            a
                            specific
                            plant—making it simple to start conversations and spark curiosity about the living world.
                            Use
                            them to
                            supplement textbook chapters with real-world examples.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>Why do animals need to keep clean or groom themselves?</li>
                            <li>How does the interaction on this chart help both species?</li>
                            <li>What other animal behaviors have you observed in domestic pets?</li>
                            <li>Can you find a real-life example of this interaction outdoors?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}