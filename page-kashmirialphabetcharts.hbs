{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}
    {{#post}}
    <div class="kashmiri-alphabet-page">

        <!-- Hero Section -->
        <section class="ka-hero">
            <h1>{{title}}</h1>
            <div class="ka-hero-content">
                {{content}}
            </div>
        </section>

        <!-- Section Header -->
        <div class="ka-section-header">
            <div class="ka-section-title">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    <line x1="9" y1="7" x2="15" y2="7"></line>
                    <line x1="9" y1="11" x2="15" y2="11"></line>
                </svg>
                Resources
            </div>
            <div class="ka-section-line"></div>
        </div>

        <!-- Resource Grid -->
        <div class="ka-grid">
            {{#get "posts" filter="tag:hash-hash-kashmiri-alphabet" order="published_at asc" include="tags"
            formats="html"}}
            {{#foreach posts}}
            {{> "icons/resource-item"
            title=title
            description=html
            preview_image=feature_image
            download_url=url
            custom_link=meta_description
            is_explore=true
            }}
            {{/foreach}}
            {{/get}}
        </div>

        {{#get "posts" filter="tag:hash-sec-kashmiri-note" limit="1"}}
        {{#foreach posts}}
        <section class="ka-educator-note-section">
            <div class="container">
                <div class="ka-educator-note-card">
                    <div class="ka-educator-note-header">
                        <div class="ka-educator-icon">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                            </svg>
                        </div>
                        <h2 class="ka-educator-title">{{title}}</h2>
                    </div>
                    <div class="ka-educator-content">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        <!-- Explore More Section -->
        <section class="ka-explore-more">
            <a href="/alphabet-charts/" class="ka-explore-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Explore More Alphabet Charts
            </a>
        </section>

    </div>
    {{/post}}