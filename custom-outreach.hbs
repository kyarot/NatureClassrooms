{{!< default}} <div class="outreach-page">
    <div class="outreach-page-illustration" data-reveal>
        <img src="{{asset 'illustrations/26.PNG'}}" alt="">
    </div>
    <!-- Compact Hero Section -->
    <header class="outreach-hero">
        <div class="outreach-hero-bg"></div>
        <div class="outreach-hero-overlay"></div>
        <div class="outreach-hero-content">
            <h1 style="color: white;">Outreach & Public Engagement</h1>
        </div>
    </header>

    <!-- Intro Section -->
    <section class="outreach-intro">
        <div class="outreach-container">
            <div class="intro-box">
                <p>
                    Our initiatives aim to take Nature Classrooms’ approach to the wider community of educators,
                    platform dialogues, and enable sharing experiences and co-learning opportunities.
                </p>
                <p class="sub-intro">
                    By facilitating meet-ups, talks, workshops, and creative collaborations, we connect with students,
                    teachers, and enthusiasts to reimagining nature in everyday life.
                </p>
            </div>
        </div>
    </section>

    <!-- Initiatives Grid -->
    <section class="outreach-initiatives">
        <div class="outreach-container">
            <div class="initiative-grid">
                <!-- Communities of Practice -->
                <div class="initiative-card">
                    <div class="card-image">
                        <img src="{{asset 'research/res2.JPG'}}" alt="Communities of Practice">
                    </div>
                    <div class="card-body">
                        <h3>Communities of Practice</h3>
                        <p>An online series, in collaboration with Wipro Foundation, exploring diverse topics and themes
                            relevant to nature learning.</p>
                        <a href="https://www.natureclassrooms.org/communitiesofpractice" class="btn-text">Read More</a>
                    </div>
                </div>

                <!-- Nature Educators Meet-ups -->
                <div class="initiative-card">
                    <div class="card-image">
                        <img src="{{asset 'research/res3.jpg'}}" alt="Nature Educators Meet-ups">
                    </div>
                    <div class="card-body">
                        <h3>Nature Educators Meet-ups</h3>
                        <p>A growing community across Bengaluru, Mumbai, Goa, and Chennai, connecting educators to
                            reflect and explore creative nature learning.</p>
                        <a href="https://www.natureclassrooms.org/natureeducator" class="btn-text">Read More</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Compact Contact Section -->
    <section class="outreach-contact">
        <div class="outreach-container">
            <div class="contact-strip">
                <h2>Looking to collaborate?</h2>
                <p>Facilitate a meet-up or workshop with us.</p>
                <a href="mailto:info@natureclassrooms.in" class="btn-solid">Get in Touch</a>
            </div>
        </div>
    </section>
    </div>