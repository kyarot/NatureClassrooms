{{!< default}} {{#post}} <div class="outreach-page">
    {{!-- 1. Hero Section (Source: Page) --}}
    <header class="outreach-hero">
        <div class="outreach-hero-bg" style="background-image: url('{{feature_image}}');"></div>
        <div class="outreach-hero-overlay"></div>
        <div class="outreach-hero-content">
            <h1 style="color: white;">{{title}}</h1>
            {{#if content}}
            <div class="outreach-hero-description" style="margin-top: 20px; font-size: 1.2rem; opacity: 0.9;">
                {{content}}
            </div>
            {{/if}}
        </div>
    </header>

    {{!-- 2. Intro Section (Post #sec-outreach-intro) --}}
    {{#get "posts" filter="tag:hash-sec-outreach-intro" limit="1"}}
    {{#foreach posts}}
    <section class="outreach-intro">
        <div class="outreach-container">
            <div class="intro-box">
                {{content}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- 3. Initiatives Grid (Posts #card-outreach-initiative) --}}
    <section class="outreach-initiatives">
        <div class="outreach-container">
            <div class="initiative-grid">
                {{#get "posts" limit="100" filter="tag:hash-card-outreach-initiative" include="tags,authors"
                order="published_at asc"}}
                {{#foreach posts}}
                <div class="initiative-card">
                    <div class="card-image">
                        {{#if feature_image}}
                        <img src="{{feature_image}}" alt="{{title}}">
                        {{/if}}
                    </div>
                    <div class="card-body">
                        <h3>{{title}}</h3>
                        {{content}}
                        {{#if meta_description}}
                        <a href="{{meta_description}}" class="btn-text">Read More</a>
                        {{/if}}
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- 4. Contact/CTA Section (Post #sec-outreach-cta) --}}
    {{#get "posts" filter="tag:hash-sec-outreach-cta" limit="1"}}
    {{#foreach posts}}
    <section class="outreach-contact">
        <div class="outreach-container">
            <div class="contact-strip">
                <h2>{{title}}</h2>
                {{content}}
                {{#if meta_description}}
                <div style="margin-top: 30px;">
                    <a href="{{meta_description}}" class="btn-solid">Get in Touch</a>
                </div>
                {{/if}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    </div>
    {{/post}}