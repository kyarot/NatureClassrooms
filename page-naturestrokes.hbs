{{!< default}} {{#post}} <div class="nature-strokes-page">

    <!-- Hero Section -->
    <section class="ns-hero">
        <h1>{{title}}</h1>
        <div class="ns-hero-content">
            {{#if content}}
            <div class="ghost-content">
                {{content}}
            </div>
            {{else}}
            <p>{{custom_excerpt}}</p>
            {{/if}}
        </div>
    </section>

    <!-- Resources Section -->
    <div class="ns-grid">
        {{!-- 1. Dynamic Content (Ghost) --}}
        {{#get "posts" filter="tag:#hash-nature-stroke" order="published_at desc" include="tags"}}
        {{#foreach posts}}
        <div class="ns-card">
            <div class="ns-card-img">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
                <div class="ns-card-overlay">
                    <a href="{{url}}" class="ns-overlay-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Explore
                    </a>
                </div>
            </div>
            <div class="ns-card-content">
                <h3>{{title}}</h3>
                <p class="ns-card-desc">{{custom_excerpt}}</p>
                <div class="ns-card-footer">
                    <a href="{{url}}" class="ns-download-btn">
                        Explore Resource
                    </a>
                </div>
            </div>
        </div>
        {{/foreach}}
        {{/get}}
    </div>

    <!-- Explore More Section -->
    <section class="ns-explore-more">
        <a href="/modules/" class="ns-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Explore More Learning Modules
        </a>
    </section>

    </div>
    {{/post}}