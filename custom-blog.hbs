{{!< default}} {{#post}} <div class="blog-page">

    <!-- Hero Section -->
    <section class="blog-hero">
        <div class="blog-hero-content">
            <h1>{{#if title}}{{title}}{{else}}Blog{{/if}}</h1>
        </div>
    </section>

    {{#if content}}
    <div class="blog-dynamic-content">
        <div class="container">
            {{content}}
        </div>
    </div>
    {{/if}}

    <!-- Note Box -->
    {{#get "posts" filter="tag:hash-sec-blog-note" limit="1"}}
    {{#foreach posts}}
    <div class="blog-note-container">
        <div class="blog-note-box">
            <div class="blog-note-content">
                {{content}}
            </div>
        </div>
    </div>
    {{/foreach}}
    {{/get}}

    <!-- Latest Stories -->
    <div class="stories-header">
        <div class="stories-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 8a7 7 0 0 1-9 10z"></path>
                <line x1="9" y1="21" x2="12" y2="11"></line>
            </svg>
            Latest Stories
        </div>
        <div class="stories-line"></div>
        <div class="stories-count">{{posts.length}} posts</div>
    </div>

    <div class="blog-grid">
        <!-- Ghost Dynamic Posts Loop -->
        {{#get "posts" filter="tag:blog" limit="10" include="authors,tags"}}
        {{#foreach posts}}
        <!-- Unified Post Card -->
        <a href="{{url}}" class="post-card">
            <div class="post-card-img">
                {{#if feature_image}}
                <img src="{{img_url feature_image}}" alt="{{title}}">
                {{else}}
                <div class="placeholder-img" style="background: #e9ecef; width:100%; height:100%;"></div>
                {{/if}}
                <div class="arrow-overlay">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M7 17l10-10M17 17V7H7"></path>
                    </svg>
                </div>
            </div>
            <div class="post-card-content">
                <div class="author-meta">
                    <div class="author-avatar">
                        {{#primary_author}}
                        {{#if profile_image}}
                        <img src="{{img_url profile_image}}" alt="{{name}}">
                        {{else}}
                        {{name.[0]}}{{name.[1]}}
                        {{/if}}
                        {{/primary_author}}
                    </div>
                    <div class="author-info">
                        <span class="author-name">{{primary_author.name}}</span>
                        <span class="post-read-time">
                            <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor"
                                stroke-width="2.5" style="margin-right: 4px; vertical-align: -2px;">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            {{reading_time}}
                        </span>
                    </div>
                </div>
                <h3>{{title}}</h3>
                <p class="post-card-excerpt">{{excerpt words="20"}}...</p>
                <div class="card-stats">
                    <div class="stat-item">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        {{date published_at format="MMM DD, YYYY"}}
                    </div>
                </div>
            </div>
        </a>
        {{/foreach}}
        {{else}}
        <p>No posts found.</p>
        {{/get}}
    </div>

    </div>
    {{/post}}