{{!< default}} {{#post}} <div class="hidden-housemates-page">

    <!-- Hero Section -->
    <section class="hh-hero">
        <h1>{{#if title}}{{title}}{{else}}Hidden Housemates{{/if}}</h1>
        <div class="hh-hero-subtitle">
            {{#if content}}
            {{content}}
            {{else}}
            <p>Uncover the creatures and natural phenomena that often go unnoticed, right inside your home or school.
                These bingo sheets and the accompanying activity sheets invite you to closely observe everyday spaces,
                fostering an understanding of urban biodiversity.</p>
            {{/if}}
        </div>
    </section>

    <!-- Section Header -->
    <div class="hh-section-header">
        <div class="hh-section-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Bingo Sheets
        </div>
        <div class="hh-section-line"></div>
        <div class="hh-section-count">Resources</div>
    </div>

    <!-- Resource Grid -->
    <div class="hh-grid">
        {{#get "posts" filter="tag:#hash-hidden-housemates" order="published_at desc" include="tags"}}
        {{#foreach posts}}
        <div class="hh-card">
            <div class="hh-card-img">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
                <div class="hh-card-overlay">
                    <a href="{{url}}" class="hh-overlay-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Explore
                    </a>
                </div>
            </div>
            <div class="hh-card-content">
                <h3>{{title}}</h3>
                <p class="hh-card-desc">{{custom_excerpt}}</p>
                <div class="hh-card-footer">
                    <a href="{{url}}" class="hh-download-btn">
                        Explore Resource
                    </a>
                </div>
            </div>
        </div>
        {{/foreach}}
        {{else}}
        {{!-- Fallback to original content --}}
        <!-- Hidden Housemates (1) -->
        <div class="hh-card">
            <div class="hh-card-img">
                <img src="{{asset 'hh/h1.png'}}" alt="Hidden Housemates (1)">
                <div class="hh-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 1 (English, digital).pdf'}}"
                        class="hh-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="hh-card-content">
                <h3>Hidden Housemates (1)</h3>
                <p class="hh-card-desc">Discover the tiny creatures sharing your living spaces — from spiders to
                    silverfish, they're all around.</p>
                <div class="hh-card-footer">
                    <div class="hh-download-dropdown">
                        <button class="hh-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="hh-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 1 (English, digital).pdf'}}"
                                class="hh-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Hindi/Copy of प्रकृति की पोटಲಿ 1_Hidden Housemates 1 (Hindi)_NatureClassrooms.pdf'}}"
                                class="hh-dropdown-item">हिन्दी</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Kannada/Kannada Hidden Housemates 1.pdf'}}"
                                class="hh-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hidden Housemates (2) -->
        <div class="hh-card">
            <div class="hh-card-img">
                <img src="{{asset 'hh/h2.png'}}" alt="Hidden Housemates (2)">
                <div class="hh-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 2 (English, digital).pdf'}}"
                        class="hh-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="hh-card-content">
                <h3>Hidden Housemates (2)</h3>
                <p class="hh-card-desc">Continue the exploration — more creatures and signs of nature hiding in plain
                    sight inside your spaces.</p>
                <div class="hh-card-footer">
                    <div class="hh-download-dropdown">
                        <button class="hh-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="hh-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 2 (English, digital).pdf'}}"
                                class="hh-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Hindi/Copy of प्रकृति की पोटલી 2_Hidden Housemates 2 (Hindi)_NatureClassrooms.pdf'}}"
                                class="hh-dropdown-item">हिन्दी</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Kannada/Kannada Hidden Housemates 2.pdf'}}"
                                class="hh-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hidden Housemates (3) -->
        <div class="hh-card">
            <div class="hh-card-img">
                <img src="{{asset 'hh/h3.png'}}" alt="Hidden Housemates (3)">
                <div class="hh-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 3 (English, digital).pdf'}}"
                        class="hh-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="hh-card-content">
                <h3>Hidden Housemates (3)</h3>
                <p class="hh-card-desc">The final set — uncover even more biodiversity thriving within indoor and urban
                    environments.</p>
                <div class="hh-card-footer">
                    <div class="hh-download-dropdown">
                        <button class="hh-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="hh-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/English/Copy of Hidden Housemates 3 (English, digital).pdf'}}"
                                class="hh-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Hindi/Copy of प्रकृति की पोटલી 3_Hidden Housemates 3 (Hindi)_NatureClassrooms.pdf'}}"
                                class="hh-dropdown-item">हिन्दी</a>
                            <a href="{{asset 'files/Resources/Bingos/Hidden Housemates/Kannada/Kannada Hidden Housemates 3.pdf'}}"
                                class="hh-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/get}}
    </div>

    <!-- Educator Note Section -->
    <section class="hh-educator-note-section">
        <div class="container">
            <div class="hh-educator-note-card">
                <div class="hh-educator-note-header">
                    <div class="hh-educator-icon">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                    </div>
                    <h2 class="hh-educator-title">Note for Educators</h2>
                </div>
                <div class="hh-educator-content">
                    <p>Hidden Housemates works well for both young and older audiences and is a great way to engage
                        people in nature observation, even when outdoor spaces are not accessible. It is perfect for
                        educators to assign as "nature homework" to explore their homes or for in-class activities
                        within school premises.</p>
                </div>
                <div class="hh-educator-activities">
                    <span class="hh-activities-title">Activity Ideas</span>
                    <ul class="hh-activities-list">
                        <li>Ask learners to draw the different housemates they find</li>
                        <li>Research the roles of each creature in the indoor environment</li>
                        <li>Observe and note where different housemates like to reside</li>
                        <li>Create simple indoor ecosystem maps</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    </div>
    {{/post}}