{{!< default}} {{#post}} <div class="cnc-page">

    <!-- Hero Section -->
    <section class="cnc-hero">
        <h1>{{title}}</h1>
        <p class="cnc-hero-subtitle">{{custom_excerpt}}</p>
    </section>

    <!-- About Section -->
    <section class="cnc-about-section">
        <div class="cnc-about-card">
            <div class="cnc-about-content">
                {{content}}
            </div>
        </div>
    </section>

    <!-- Team Members Section -->
    <section class="cnc-team-section">
        <div class="cnc-team-container">
            <h2 class="cnc-section-title">Team Members</h2>
            <div class="cnc-team-grid">
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Aashish Gokhale</a>
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Kaustubh Rau</a>
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Vena Kapoor</a>
                <a href="https://www.ncf-india.org/author/647029/roshni-ravi" target="_blank" rel="noopener"
                    class="cnc-team-member">Roshni Ravi</a>
                <a href="https://www.linkedin.com/in/ovee-thorat-31295310a/" target="_blank" rel="noopener"
                    class="cnc-team-member">Ovee Thorat</a>
                <a href="https://www.ncf-india.org/author/646394/suhel-quader" target="_blank" rel="noopener"
                    class="cnc-team-member">Suhel Quader</a>
            </div>
        </div>
    </section>

    <!-- Download Section -->
    <section class="cnc-download-section">
        <div class="cnc-download-card">
            <div class="cnc-download-info">
                <h3 class="cnc-download-title">Download Report</h3>
                <div class="cnc-download-buttons">
                    <a href="{{asset 'files/Our Work/Research/Child Nature Ooru.pdf'}}" class="cnc-download-btn"
                        download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Partner Section -->
    <section class="cnc-partners-section">
        <div class="cnc-partners-container">
            <div class="cnc-partners-block">
                <h3 class="cnc-partners-title">Partner</h3>
                <div class="cnc-partners-logos">
                    <a href="https://azimpremjiuniversity.edu.in/" target="_blank" rel="noopener">
                        <img src="{{asset 'collaborators/Azim_Premji_University_logo.png'}}"
                            alt="Azim Premji University">
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Back to Projects -->
    <section class="cnc-explore-more">
        <a href="/" class="cnc-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}