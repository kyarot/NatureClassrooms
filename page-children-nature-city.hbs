{{!< default}} {{#post}} <div class="cnc-page">

    <!-- Hero Section -->
    <section class="cnc-hero">
        <h1>{{title}}</h1>
        <div class="cnc-hero-subtitle">{{content}}</div>
    </section>

    <!-- About Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-cnc-about" limit="1"}}
    {{#foreach posts}}
    <section class="cnc-about-section">
        <div class="cnc-about-card">
            <div class="cnc-about-content resource-item-desc">
                {{content}}
            </div>
            <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                style="margin-top: 20px;">
                <div class="dynamic-download-container" style="display: none;">
                    <div class="download-dropdown">
                        <button class="download-dropdown-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="dropdown-menu dynamic-menu"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    <!-- Team Members Section -->
    <section class="cnc-team-section">
        <div class="cnc-team-container">
            <h2 class="cnc-section-title">Team Members</h2>
            <div class="cnc-team-grid">
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Aashish Gokhale</a>
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Kaustubh Rau</a>
                <a href="https://www.ncf-india.org/author/646987/vena-kapoor-2" target="_blank" rel="noopener"
                    class="cnc-team-member">Vena Kapoor</a>
                <a href="https://www.ncf-india.org/author/647029/roshni-ravi" target="_blank" rel="noopener"
                    class="cnc-team-member">Roshni Ravi</a>
                <a href="https://www.linkedin.com/in/ovee-thorat-31295310a/" target="_blank" rel="noopener"
                    class="cnc-team-member">Ovee Thorat</a>
                <a href="https://www.ncf-india.org/author/646394/suhel-quader" target="_blank" rel="noopener"
                    class="cnc-team-member">Suhel Quader</a>
            </div>
        </div>
    </section>

    <!-- Download Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-cnc-download" limit="1"}}
    {{#foreach posts}}
    <section class="cnc-download-section">
        <div class="cnc-download-card">
            <div class="cnc-download-info">
                <h3 class="cnc-download-title">{{title}}</h3>
                <div class="cnc-download-content resource-item-desc">
                    {{content}}
                </div>
                <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                    style="margin-top: 20px;">
                    <div class="dynamic-download-container" style="display: none;">
                        <div class="download-dropdown">
                            <button class="download-dropdown-btn">
                                <span>Download</span>
                                <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="dropdown-menu dynamic-menu"></div>
                        </div>
                    </div>
                </div>
                {{#if custom_excerpt}}
                <p class="cnc-download-credit">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{else}}
    {{!-- Fallback if no post is found --}}
    <section class="cnc-download-section">
        <div class="cnc-download-card">
            <div class="cnc-download-info">
                <h3 class="cnc-download-title">Download Report</h3>
                <p class="cnc-download-credit">No reports available for download yet.</p>
            </div>
        </div>
    </section>
    {{/get}}

    <!-- Partner Section -->
   <section class="partners-section">

        <div class="container">
            <h2 class="partners-title" style="font-size: 50px; margin-bottom: 50px;">Our Partners</h2>

            <div class="partners-grid">
                {{#get "posts" filter="tag:hash-sec-cnc-partners" order="published_at asc"}}
                {{#foreach posts}}
                <div class="partner-card">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{else}}
                    <span class="partner-name">{{title}}</span>
                    {{/if}}
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    <!-- Back to Projects -->
    <section class="cnc-explore-more">
        <a href="/" class="cnc-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}