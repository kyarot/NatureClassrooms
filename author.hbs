{{!< default}} <section class="author-page site-section">
    <div class="container">
        {{#author}}
        <div class="author-card">
            <div class="author-avatar-wrapper">
                {{#if profile_image}}
                <img class="author-avatar" src="{{img_url profile_image}}" alt="{{name}}">
                {{else}}
                <div class="author-avatar author-avatar-fallback">
                    <span class="author-initial">{{name.[0]}}</span>
                </div>
                {{/if}}
            </div>

            <div class="author-details">
                <h1 class="author-name">{{name}}</h1>
                {{#if bio}}<p class="author-bio">{{bio}}</p>{{/if}}

                <div class="author-stats">
                    <div class="author-stat">
                        <span class="author-stat-value">{{../pagination.total}}</span>
                        <span class="author-stat-label">{{plural ../pagination.total empty="posts" singular="post"
                            plural="posts"}}</span>
                    </div>
                    {{#if location}}
                    <span class="author-stat-divider">•</span>
                    <div class="author-stat">
                        <span class="author-stat-value">{{location}}</span>
                    </div>
                    {{/if}}
                </div>

                <div class="author-social-links">
                    {{#if facebook}}
                    <a href="{{social_url type=" facebook"}}" class="author-social-link">{{> "icons/facebook"}}</a>
                    {{/if}}
                    {{#if twitter}}
                    <a href="{{social_url type=" twitter"}}" class="author-social-link">{{> "icons/twitter"}}</a>
                    {{/if}}
                    {{#if website}}
                    <a href="{{website}}" class="author-social-link" target="_blank" rel="noopener">{{>
                        "icons/link"}}</a>
                    {{/if}}
                </div>
            </div>
        </div>
        {{/author}}
    </div>

    <section class="author-posts site-section">
        <div class="container">
            {{#author}}
            <h2 class="author-posts-title">{{name}}'s Stories</h2>
            {{/author}}

            {{#if posts}}
            <div class="post-grid">
                {{#foreach posts}}
                <article class="post-card {{post_class}}">
                    <a href="{{url}}" class="post-card-link">
                        {{#if feature_image}}
                        <div class="post-card-image" style="background-image: url('{{img_url feature_image}}');"></div>
                        {{else}}
                        <div class="post-card-image post-card-no-image"></div>
                        {{/if}}
                        <div class="post-card-content">
                            <h3 class="post-card-title">{{title}}</h3>
                        </div>
                    </a>
                </article>
                {{/foreach}}
            </div>
            {{pagination}}
            {{/if}}
        </div>
    </section>
    </section>