{{!< default}} {{#post}} <div class="media-page">

    {{!-- Hero Section (Source: Page) --}}
    <section class="media-hero" {{#if feature_image}}style="background-image: url('{{img_url feature_image}}');"
        {{/if}}>
        <div class="media-hero-content">
            <div class="media-hero-tag">
                {{custom_excerpt}}
            </div>
            <h1 style="color: white;">{{title}}</h1>
        </div>
    </section>

    {{#if content}}
    <section class="media-dynamic-content">
        <div class="container" style="padding: 60px 20px;">
            {{content}}
        </div>
    </section>
    {{/if}}

    {{!-- Articles & Publications --}}
    {{#get "posts" filter="tag:hash-sec-media-articles" limit="1"}}
    {{#foreach posts}}
    <section class="media-stories-section">
        <div class="section-header">
            <div class="section-label">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Articles & Publications{{/if}}
            </div>
            <h2>{{title}}</h2>
            {{content}}
        </div>

        <div class="media-filters">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="press">Press</button>
            <button class="filter-btn" data-filter="research">Research</button>
            <button class="filter-btn" data-filter="publication">Publication</button>
            <button class="filter-btn" data-filter="blog">Blog</button>
        </div>

        <div class="media-grid">
            {{#get "posts" limit="100" filter="tag:hash-media-article" include="tags,authors" order="published_at desc"}}
            {{#foreach posts}}
            <div class="media-card" data-category="{{primary_tag.slug}}">
                <a href="{{#if meta_description}}{{meta_description}}{{else}}#{{/if}}" target="_blank" rel="noopener">
                    <div class="media-card-img">
                        <span class="media-category-badge {{primary_tag.slug}}">{{primary_tag.name}}</span>
                        {{#if feature_image}}
                        <img src="{{img_url feature_image}}" alt="{{title}}">
                        {{/if}}
                    </div>
                    <div class="media-card-content">
                        {{#if excerpt}}
                        <span class="media-publisher">{{excerpt}}</span>
                        {{/if}}
                        <h3>{{title}}</h3>
                        <div class="media-article-content">
                            {{content}}
                        </div>
                        <p class="media-author">{{authors}}</p>
                    </div>
                </a>
            </div>
            {{/foreach}}
            {{/get}}
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- Podcast Section --}}
    {{#get "posts" filter="tag:hash-sec-media-podcasts" limit="1"}}
    {{#foreach posts}}
    <section class="podcast-section">
        <div class="section-header">
            <div class="section-label">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Podcasts{{/if}}</div>
            <h2>{{title}}</h2>
            <div class="media-hero-description" style="margin: 20px 0; color: #666; text-align: left;">
                {{content}}
            </div>
        </div>

        <div class="podcast-grid">
            {{#get "posts" limit="100" filter="tag:hash-media-podcast" include="tags,authors" order="published_at desc"}}
            {{#foreach posts}}
            <div class="podcast-card">
                <div class="podcast-thumb">
                    {{#if feature_image}}
                    <img src="{{img_url feature_image}}" alt="{{title}}">
                    {{/if}}
                </div>
                <div class="podcast-content">
                    <div class="podcast-label">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
                            <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                            <line x1="12" y1="19" x2="12" y2="23" />
                            <line x1="8" y1="23" x2="16" y2="23" />
                        </svg>
                        {{primary_tag.name}}
                    </div>
                    <h3>{{title}}</h3>
                    <div class="podcast-description" style="margin-bottom: 20px; opacity: 0.8;">
                        {{content}}
                    </div>
                    {{#if meta_description}}
                    <a href="{{meta_description}}" target="_blank" rel="noopener" class="podcast-link">Listen Now →</a>
                    {{/if}}
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    </div>

    <script>
        // Simple Filter Logic
        document.addEventListener('DOMContentLoaded', function () {
            const filterBtns = document.querySelectorAll('.filter-btn');
            const mediaCards = document.querySelectorAll('.media-card');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    // Update active state
                    filterBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    const filter = btn.getAttribute('data-filter');

                    mediaCards.forEach(card => {
                        if (filter === 'all' || card.getAttribute('data-category') === filter) {
                            card.style.display = 'block';
                            setTimeout(() => card.style.opacity = '1', 10);
                        } else {
                            card.style.opacity = '0';
                            setTimeout(() => card.style.display = 'none', 300);
                        }
                    });
                });
            });
        });
    </script>
    {{/post}}