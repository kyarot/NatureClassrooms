{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main" style="position: relative;">
        {{!-- Floating Illustration Overlay --}}
        <div class="page-top-illustration" data-reveal>
            <img src="{{asset 'illustrations/31.PNG'}}" alt="">
        </div>

        <div class="page-middle-illustration" data-reveal>
            <img src="{{asset 'illustrations/16.PNG'}}" alt="">
        </div>

        <div class="page-bottom-illustration" data-reveal>
            <img src="{{asset 'illustrations/25.PNG'}}" alt="">
        </div>

        {{!-- 1. Enhanced Hero Section --}}
        <section class="resources-hero hero-v2">
            <div class="resources-hero-bg" style="background-image: url('{{asset "carousel/1.jpg"}}');"></div>
            <div class="resources-hero-overlay"></div>

            {{!-- Decorative shapes --}}
            <div class="hero-decorative-blobs">
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
            </div>

            <div class="resources-hero-content">
                <h1 class="resources-hero-title" data-reveal>
                    <span class="title-cursive">Our Nature classrooms</span>
                    <span class="title-bold">Resources</span>
                </h1>
                <div class="title-separator" data-reveal></div>
                <p class="resources-hero-subtitle" data-reveal>
                    The Nature Learning Resources featured here span a variety of topics from the current EVS curriculum followed in India. Designed to be age-appropriate, they are organized into different themes, available in multiple languages, and some of the resources are adapted to specific regions as well. We regularly add new resources as they are developed, and you can find updates about our latest releases on our social media.
                </p>


            </div>
        </section>

        {{!-- 2. Resource Category Grid --}}
        <section class="resources-grid-section">
            <div class="container">
                <div class="resources-grid-header" data-reveal>
                    <span class="grid-category-label">Explore</span>
                    <h2 class="grid-title">Resource Categories</h2>
                    <div class="title-separator" style="margin: 20px auto;"></div>
                </div>
                <div class="resources-grid" data-reveal>
                    {{!-- Bingos --}}
                    {{> "resource-card" url="/resources/bingos/" title="Bingos" description="Fun, interactive
                    nature-themed
                    bingo games for all ages." icon="bingos/Nature_Bingo.png"}}

                    {{!-- Alphabet Charts --}}
                    {{> "resource-card" url="/resources/alphabet-charts/" title="Alphabet Charts" description="Learn the
                    ABCs through the wonders of the natural world." icon="alphabets/Bird_Alphabet_Chart.png"}}

                    {{!-- Anchor Charts --}}
                    {{> "resource-card" url="/resources/anchor-charts/" title="Anchor Charts" description="Visual aids
                    to
                    ground learning in natural concepts." icon="anchor/Plant_Poster.png"}}

                    {{!-- Natural History --}}
                    {{> "resource-card" url="/resources/natural-history/" title="Natural History" description="Deep
                    dives
                    into the stories of plants and animals." icon="naturalhistory/Fig_and_Wasp_Resource.png"}}

                    {{!-- Modules --}}
                    {{> "resource-card" url="/resources/modules/" title="Modules" description="Comprehensive learning
                    units
                    for structured nature education." icon="modules/Water_Module.png"}}

                    {{!-- Activities --}}
                    {{> "resource-card" url="/resources/activities/" title="Activities" description="Hands-on projects
                    and
                    experiments to do outdoors." icon="activities/Colours.png"}}

                    {{!-- There's Nothing There --}}
                    {{> "resource-card" url="/resources/theres-nothing-there/" title="Story Books"
                    description="A
                    unique series challenging how we perceive 'empty' spaces." icon="storybooks/storybooks.png"}}
                </div>
            </div>
        </section>

        {{!-- 3. Illustration Section (Engagement) --}}
        <section class="resource-illustration-section">
            <div class="curve-separator"></div>
            <div class="container">
                <div class="illustration-grid" data-reveal>
                    <div class="illustration-image" data-reveal>
                        <img src="{{asset "images/ant-aphids.png"}}" alt="Learning through Nature">
                    </div>
                    <div class="illustration-text" data-reveal>
                        <h2 class="illustration-title">Learning Through Nature</h2>
                        <p class="illustration-description">
                            We believe that every leaf, insect, and trail has a story to tell. Our resources are
                            designed to
                            turn the outdoors into a living classroom, fostering curiosity and a lifelong love for the
                            environment.
                        </p>
                    </div>
                </div>
            </div>
            <div class="curve-separator-bottom"></div>
        </section>


    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}