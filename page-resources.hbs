{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main" style="position: relative;">
        {{!-- Floating Illustration Overlay --}}
        <div class="page-top-illustration" data-reveal>
            <img src="{{asset 'illustrations/31.PNG'}}" alt="">
        </div>

        <div class="page-middle-illustration" data-reveal>
            <img src="{{asset 'illustrations/16.PNG'}}" alt="">
        </div>

        {{!-- 1. Enhanced Hero Section --}}
        <section class="resources-hero hero-v2">
            <div class="resources-hero-bg"
                style="background-image: url('{{#if feature_image}}{{feature_image}}{{else}}{{asset "carousel/1.jpg"}}{{/if}}');"></div>
            <div class="resources-hero-overlay"></div>

            {{!-- Decorative shapes --}}
            <div class="hero-decorative-blobs">
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
            </div>

            <div class="resources-hero-content">
                <h1 class="resources-hero-title" data-reveal>
                    {{#if title}}
                    <span class="title-bold">{{title}}</span>
                    {{else}}
                    <span class="title-cursive">Our Nature classrooms</span>
                    <span class="title-bold">Resources</span>
                    {{/if}}
                </h1>
                <div class="title-separator" data-reveal></div>
                <p class="resources-hero-subtitle" data-reveal>
                    {{#if custom_excerpt}}{{custom_excerpt}}{{else}}The Nature Learning Resources featured here span a
                    variety of topics from the current EVS curriculum followed in India. Designed to be age-appropriate,
                    they are organized into different themes, available in multiple languages, and some of the resources
                    are adapted to specific regions as well. We regularly add new resources as they are developed, and
                    you can find updates about our latest releases on our social media.{{/if}}
                </p>
            </div>
        </section>

        {{#if content}}
        <section class="resources-dynamic-content">
            <div class="container" style="padding: 100px 20px;">
                {{content}}
            </div>
        </section>
        {{/if}}

        {{!-- 2. Resource Category Grid --}}
        <section class="resources-grid-section">
            <div class="container">
                <div class="resources-grid-header" data-reveal>
                    <span class="grid-category-label">Explore</span>
                    <h2 class="grid-title">Resource Categories</h2>
                    <div class="title-separator" style="margin: 20px auto;"></div>
                </div>
                <div class="resources-grid" data-reveal>
                    {{#get "posts" limit="100" filter="tag:#resource-category" include="tags,authors"}}
                    {{#foreach posts}}
                    <a href="{{excerpt}}" class="resource-category-card">
                        <div class="resource-card-icon">
                            {{#if feature_image}}
                            <img src="{{img_url feature_image}}" alt="{{title}}">
                            {{else}}
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                            </svg>
                            {{/if}}
                        </div>
                        <h3 class="resource-card-title">{{title}}</h3>
                        <div class="resource-card-description">{{content}}</div>
                        <span class="resource-card-btn">
                            Explore Resources
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        </span>
                    </a>
                    {{/foreach}}
                    {{/get}}

                    {{!-- Bingos --}}
                    {{> "icons/resource-card" url="/resources/bingos/" title="Bingos" description="Fun, interactive
                    nature-themed bingo games for all ages." icon="bingos/Nature_Bingo.png"}}

                    {{!-- Alphabet Charts --}}
                    {{> "icons/resource-card" url="/resources/alphabet-charts/" title="Alphabet Charts"
                    description="Learn the ABCs through the wonders of the natural world."
                    icon="alphabets/Bird_Alphabet_Chart.png"}}

                    {{!-- Anchor Charts --}}
                    {{> "icons/resource-card" url="/resources/anchor-charts/" title="Anchor Charts" description="Visual
                    aids to ground learning in natural concepts." icon="anchor/Plant_Poster.png"}}

                    {{!-- Natural History --}}
                    {{> "icons/resource-card" url="/resources/natural-history/" title="Natural History"
                    description="Deep dives into the stories of plants and animals."
                    icon="naturalhistory/Fig_and_Wasp_Resource.png"}}

                    {{!-- Modules --}}
                    {{> "icons/resource-card" url="/resources/modules/" title="Modules" description="Comprehensive
                    learning units for structured nature education." icon="modules/Water_Module.png"}}

                    {{!-- Activities --}}
                    {{> "icons/resource-card" url="/resources/activities/" title="Activities" description="Hands-on
                    projects and experiments to do outdoors." icon="activities/Colours.png"}}

                    {{!-- There's Nothing There --}}
                    {{> "icons/resource-card" url="/resources/theres-nothing-there/" title="Story Books" description="A
                    unique series challenging how we perceive 'empty' spaces." icon="storybooks/storybooks.png"}}
                </div>
            </div>
        </section>

        {{!-- 3. Illustration Section (Engagement) --}}
        <section class="resource-illustration-section">
            <div class="curve-separator"></div>
            <div class="container">
                <div class="illustration-grid" data-reveal>
                    <div class="illustration-image" data-reveal>
                        <img src="{{asset "images/ant-aphids.png"}}" alt="Learning through Nature">
                    </div>
                    <div class="illustration-text" data-reveal>
                        <h2 class="illustration-title">Learning Through Nature</h2>
                        <p class="illustration-description">
                            We believe that every leaf, insect, and trail has a story to tell. Our resources are
                            designed to turn the outdoors into a living classroom, fostering curiosity and a lifelong
                            love for the environment.
                        </p>
                    </div>
                </div>
            </div>
            <div class="curve-separator-bottom"></div>
        </section>


    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
    {{/post}}