{{!< default}} <section class="hero-carousel">
    <div class="carousel-wrapper" id="hero-carousel-wrapper">
        {{#get "posts" filter="tag:hash-sec-home-hero" order="published_at asc" limit="all"}}
        {{#foreach posts}}
        <div class="carousel-slide slide{{@number}}{{#if @first}} active{{/if}}"
            style="background-image: url('{{feature_image}}');">
        </div>
        {{/foreach}}
        {{else}}
        {{!-- Fallback if no hero posts exist --}}
        <div class="carousel-slide slide1 active" style="background-image: url('{{asset " home/h5.jpeg"}}');"></div>
        <div class="carousel-slide slide2" style="background-image: url('{{asset " home/h4.JPG"}}');"></div>
        {{/get}}
    </div>

    <div class="hero-overlay">
        <div class="hero-overlay-bg"></div>
        <div class="hero-content">
            <h1 class="hero-welcome">
                <span class="welcome-cursive">Welcome to</span>
                <span class="welcome-bold">Nature Classrooms</span>
            </h1>
            <button class="hero-read-more" id="readMoreBtn"
                onclick="document.getElementById('what-we-do').scrollIntoView({behavior:'smooth'})">Explore
                More</button>
        </div>
    </div>
    </section>

    <!-- What We Do Section -->
    {{#get "posts" filter="tag:hash-sec-home-what-we-do" limit="1"}}
    {{#foreach posts}}
    <section class="what-we-do-section" id="what-we-do">
        <div class="container">
            <h2 class="what-we-do-title" style="font-size: 50px; margin-bottom: 50px;">{{title}}</h2>
            <div class="what-we-do-wrapper">
                <div class="what-we-do-content">
                    {{content}}
                </div>

                <div class="what-we-do-image">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{else}}
                    <img src="{{asset " images/ant-aphids.png"}}" alt="Ant and Aphids Illustration">
                    {{/if}}
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{else}}
    <section class="what-we-do-section" id="what-we-do">
        <div class="container">
            <h2 class="what-we-do-title" style="font-size: 50px; margin-bottom: 50px;">What We Do?</h2>
            <div class="what-we-do-wrapper">
                <div class="what-we-do-content">
                    <p>We see nature as the ideal learning space, or classroom, and hope to blur the distinctions
                        between
                        the two...</p>
                </div>
                <div class="what-we-do-image">
                    <img src="{{asset " images/ant-aphids.png"}}" alt="Ant and Aphids Illustration">
                </div>
            </div>
        </div>
    </section>
    {{/get}}

    <!-- Our Work - Four Arms Section -->
    <section class="four-arms-section">
        <div class="container">
            <h2 class="four-arms-title" style="font-size: 50px; margin-bottom: 50px;">Our Work</h2>

            <div class="four-arms-grid">
                {{#get "posts" filter="tag:hash-sec-home-our-work" order="published_at asc"}}
                {{#foreach posts}}
                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{feature_image}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">{{title}}</h3>
                        <p class="arm-card-description">{{excerpt words="40"}}</p>
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="arm-card-btn">Read More</a>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    <!-- Partners Section -->
    <section class="partners-section">
        <div class="ant-decoration ant-left">
            <img src="{{asset " images/ant-left.png"}}" alt="">
        </div>

        <div class="ant-decoration ant-right">
            <img src="{{asset " images/ant-right.png"}}" alt="">
        </div>

        <div class="container">
            <h2 class="partners-title" style="font-size: 50px; margin-bottom: 50px;">Our Partners</h2>

            <div class="partners-grid">
                {{#get "posts" filter="tag:hash-sec-home-partners" order="published_at asc"}}
                {{#foreach posts}}
                <div class="partner-card">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{else}}
                    <span class="partner-name">{{title}}</span>
                    {{/if}}
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    <!-- Latest from the Blog -->
    <section class="home-blog-section" style="padding: 100px 0; background: #f8f9fa;">
        <div class="container">
            <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 50px;">
                <div>
                    <h2 style="font-size: 50px; margin-bottom: 10px;">Latest Stories</h2>
                    <p style="color: #666; font-size: 1.1rem;">Reflections and learnings from our journey</p>
                </div>
                <a href="/blog/" class="view-all-btn"
                    style="color: #2d5a27; font-weight: 600; text-decoration: none; border-bottom: 2px solid #2d5a27; padding-bottom: 5px;">View
                    All Stories</a>
            </div>

            <div class="blog-grid"
                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
                {{#get "posts" limit="3" include="authors,tags"}}
                {{#foreach posts}}
                <a href="{{url}}" class="post-card"
                    style="text-decoration: none; color: inherit; background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: transform 0.3s ease;">
                    <div class="post-card-img" style="aspect-ratio: 16/9; overflow: hidden;">
                        {{#if feature_image}}
                        <img src="{{img_url feature_image}}" alt="{{title}}"
                            style="width: 100%; height: 100%; object-fit: cover;">
                        {{else}}
                        <div style="width: 100%; height: 100%; background: #e9ecef;"></div>
                        {{/if}}
                    </div>
                    <div class="post-card-content" style="padding: 25px;">
                        <h3 style="font-size: 1.3rem; margin-bottom: 15px; line-height: 1.4;">{{title}}</h3>
                        <p
                            style="color: #666; font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            {{excerpt words="25"}}...</p>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <div
                                style="width: 30px; height: 30px; border-radius: 50%; background: #2d5a27; display: flex; align-items: center; justify-content: center; color: white; font-size: 0.7rem; font-weight: 600;">
                                {{primary_author.name.[0]}}</div>
                            <span style="font-size: 0.9rem; color: #444;">{{primary_author.name}}</span>
                        </div>
                    </div>
                </a>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    <!-- Collaborators Section -->
    <section class="collaborators-section">
        <div class="container">
            <h2 class="collaborators-title" style="font-size: 50px; margin-bottom: 50px;">Our Collaborators</h2>
            <div class="logo-loop-container">
                <div class="logo-loop">
                    {{#get "posts" filter="tag:hash-sec-home-collaborators" order="published_at asc" limit="100"}}
                    <div class="logo-track">
                        {{#foreach posts}}
                        <div class="logo-item">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}">
                            {{else}}
                            <span>{{title}}</span>
                            {{/if}}
                        </div>
                        {{/foreach}}
                    </div>
                    <div class="logo-track" aria-hidden="true">
                        {{#foreach posts}}
                        <div class="logo-item">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}">
                            {{else}}
                            <span>{{title}}</span>
                            {{/if}}
                        </div>
                        {{/foreach}}
                    </div>
                    {{/get}}
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let slides = document.querySelectorAll('.carousel-slide');
            let currentSlide = 0;

            function nextSlide() {
                if (slides.length <= 1) return;
                slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                slides[currentSlide].classList.add('active');
            }

            if (slides.length > 1) {
                setInterval(nextSlide, 5000);
            }
        });
    </script>