{{!< default}} <!-- Hero Carousel Section -->
    <section class="hero-carousel">
        <div class="carousel-wrapper">
            <div class="carousel-slide slide1 active" style="background-image: url('{{asset "carousel/1.jpg"}}');">
            </div>
            <div class="carousel-slide slide2" style="background-image: url('{{asset "carousel/2.jpg"}}');">
            </div>
            <div class="carousel-slide slide3" style="background-image: url('{{asset "carousel/3.jpg"}}');">
            </div>
        </div>

        <div class="hero-overlay">
            <div class="hero-overlay-bg"></div>
            <div class="hero-content">
                <h1 class="hero-welcome">
                    <span class="welcome-cursive">Welcome to</span>
                    <span class="welcome-bold">Nature Classrooms</span>
                </h1>
                <p class="hero-tagline">
                    Blurring the boundaries between nature and learning, one adventure at a time.
                </p>
                <button class="hero-read-more" id="readMoreBtn" onclick="window.location.href='/resources/'">Explore
                    More</button>
            </div>
        </div>
    </section>

    <!-- What We Do Section -->
    <section class="what-we-do-section">
        <div class="container">
            <h2 class="what-we-do-title" style="font-size: 50px; margin-bottom: 50px;">What We Do?</h2>
            <div class="what-we-do-wrapper">
                <div class="what-we-do-content">
                    <p>
                        We see nature as the ideal learning space, or classroom, and hope to blur the distinctions
                        between the two —
                        which inspired the name "Nature Classrooms".
                    </p>
                    <p>
                        Nature Classrooms programme works in collaboration with Youth Conservation Action Network
                        (YouCAN).
                    </p>
                </div>

                <div class="what-we-do-image">
                    <img src="{{asset "images/ant-aphids.png"}}" alt="Ant and Aphids Illustration">
                </div>
            </div>
        </div>
    </section>

    <!-- Our Work - Four Arms Section -->
    <section class="four-arms-section">
        <div class="container">
            <h2 class="four-arms-title" style="font-size: 50px; margin-bottom: 50px;">Our Work</h2>

            <div class="four-arms-grid">

                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{asset "fourarms/ResourceCreation.jpg"}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">Resource Creation</h3>
                        <p class="arm-card-description">Browse through our growing collection of nature learning
                            resources.</p>
                        <a href="/resourcecreation/" class="arm-card-btn">Read More</a>
                    </div>
                </div>

                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{asset "fourarms/CapacityBuilding.JPG"}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">Capacity Building & Training</h3>
                        <p class="arm-card-description">We conduct immersive workshops empowering teachers.</p>
                        <a href="/capacity/" class="arm-card-btn">Read More</a>
                    </div>
                </div>

                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{asset "fourarms/Research.JPG"}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">Research</h3>
                        <p class="arm-card-description">Through our research projects, we address questions in nature
                            learning.</p>
                        <a href="/research/" class="arm-card-btn">Read More</a>
                    </div>
                </div>

                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{asset "fourarms/Outreach.jpg"}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">Outreach & Public Engagement</h3>
                        <p class="arm-card-description">We foster dialogue and collaboration.</p>
                        <a href="/outreach/" class="arm-card-btn">Read More</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

