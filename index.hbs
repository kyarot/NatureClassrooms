{{!< default}} <section class="hero-carousel">
    <div class="carousel-wrapper" id="hero-carousel-wrapper">
        {{#get "posts" filter="tag:hash-sec-home-hero" order="published_at asc" limit="all"}}
        {{#foreach posts}}
        <div class="carousel-slide slide{{@number}}{{#if @first}} active{{/if}}"
            style="background-image: url('{{feature_image}}');">
        </div>
        {{/foreach}}
        {{else}}
        {{!-- Fallback if no hero posts exist --}}
        <div class="carousel-slide slide1 active" style="background-image: url('{{asset " home/h5.jpeg"}}');"></div>
        <div class="carousel-slide slide2" style="background-image: url('{{asset " home/h4.JPG"}}');"></div>
        {{/get}}
    </div>

    <div class="hero-overlay">
        <div class="hero-overlay-bg"></div>
        <div class="hero-content">
            <h1 class="hero-welcome">
                <span class="welcome-cursive">Welcome to</span>
                <span class="welcome-bold">Nature Classrooms</span>
            </h1>
            <button class="hero-read-more" id="readMoreBtn"
                onclick="document.getElementById('what-we-do').scrollIntoView({behavior:'smooth'})">Explore
                More</button>
        </div>
    </div>
    </section>

    <!-- What We Do Section -->
    {{#get "posts" filter="tag:hash-sec-home-what-we-do" limit="1"}}
    {{#foreach posts}}
    <section class="what-we-do-section" id="what-we-do">
        <div class="container">
            <h2 class="what-we-do-title" style="font-size: 50px; margin-bottom: 50px;">{{title}}</h2>
            <div class="what-we-do-wrapper">
                <div class="what-we-do-content">
                    {{content}}
                </div>

                <div class="what-we-do-image">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{else}}
                    <img src="{{asset " images/ant-aphids.png"}}" alt="Ant and Aphids Illustration">
                    {{/if}}
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{else}}
    <section class="what-we-do-section" id="what-we-do">
        <div class="container">
            <h2 class="what-we-do-title" style="font-size: 50px; margin-bottom: 50px;">What We Do?</h2>
            <div class="what-we-do-wrapper">
                <div class="what-we-do-content">
                    <p>We see nature as the ideal learning space, or classroom, and hope to blur the distinctions
                        between
                        the two...</p>
                </div>
                <div class="what-we-do-image">
                    <img src="{{asset " images/ant-aphids.png"}}" alt="Ant and Aphids Illustration">
                </div>
            </div>
        </div>
    </section>
    {{/get}}

    <!-- Our Work - Four Arms Section -->
    <section class="four-arms-section">
        <div class="container">
            <h2 class="four-arms-title" style="font-size: 50px; margin-bottom: 50px;">Our Work</h2>

            <div class="four-arms-grid">
                {{#get "posts" filter="tag:hash-sec-home-our-work" order="published_at asc"}}
                {{#foreach posts}}
                <div class="arm-card">
                    <div class="arm-card-bg" style="background-image: url('{{feature_image}}');"></div>
                    <div class="arm-card-overlay"></div>
                    <div class="arm-card-content">
                        <h3 class="arm-card-title">{{title}}</h3>
                        <p class="arm-card-description">{{excerpt words="40"}}</p>
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="arm-card-btn">Read More</a>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    <!-- Partners Section -->
    <section class="partners-section">

        <div class="container">
            <h2 class="partners-title" style="font-size: 50px; margin-bottom: 50px;">Our Partners</h2>

            <div class="partners-grid">
                {{#get "posts" filter="tag:hash-sec-home-partners" order="published_at asc"}}
                {{#foreach posts}}
                <div class="partner-card">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{else}}
                    <span class="partner-name">{{title}}</span>
                    {{/if}}
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>


    <!-- Collaborators Section -->
    <section class="collaborators-section">
        <div class="container">
            <h2 class="collaborators-title" style="font-size: 50px; margin-bottom: 50px;">Our Collaborators</h2>
            <div class="logo-loop-container">
                <div class="logo-loop">
                    {{#get "posts" filter="tag:hash-sec-home-collaborators" order="published_at asc" limit="100"}}
                    <div class="logo-track">
                        {{#foreach posts}}
                        <div class="logo-item">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}">
                            {{else}}
                            <span>{{title}}</span>
                            {{/if}}
                        </div>
                        {{/foreach}}
                    </div>
                    <div class="logo-track" aria-hidden="true">
                        {{#foreach posts}}
                        <div class="logo-item">
                            {{#if feature_image}}
                            <img src="{{feature_image}}" alt="{{title}}">
                            {{else}}
                            <span>{{title}}</span>
                            {{/if}}
                        </div>
                        {{/foreach}}
                    </div>
                    {{/get}}
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let slides = document.querySelectorAll('.carousel-slide');
            let currentSlide = 0;

            function nextSlide() {
                if (slides.length <= 1) return;
                slides[currentSlide].classList.remove('active');
                currentSlide = (currentSlide + 1) % slides.length;
                slides[currentSlide].classList.add('active');
            }

            if (slides.length > 1) {
                setInterval(nextSlide, 5000);
            }
        });
    </script>