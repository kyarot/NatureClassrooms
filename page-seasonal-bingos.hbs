{{!< default}} {{#post}} <div class="seasonal-bingos-page">

    <!-- Hero Section -->
    <section class="sb-hero">
        <h1>{{#if title}}{{title}}{{else}}Seasonal Bingo{{/if}}</h1>
        <div class="sb-hero-content">
            <p>Seasons bring about remarkable transformations in the natural world, influencing how plants and animals
                adapt and thrive. The Seasons Bingos are a delightful and engaging way to explore these ever-dynamic
                changes right in your surroundings.</p>

            {{#if content}}
            <div class="ghost-content" style="margin-top: 2rem;">
                {{content}}
            </div>
            {{/if}}
        </div>
    </section>

    <!-- Section Header -->
    <div class="sb-section-header">
        <div class="sb-section-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 8a7 7 0 0 1-9 10z"></path>
                <line x1="9" y1="21" x2="12" y2="11"></line>
            </svg>
            Resources
        </div>
        <div class="sb-section-line"></div>
    </div>

    <!-- Resource Grid -->
    <div class="sb-grid">
        {{#get "posts" filter="tag:#hash-seasonal-bingo" order="published_at desc" include="tags"}}
        {{#foreach posts}}
        <div class="sb-card">
            <div class="sb-card-img">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
                <div class="sb-card-overlay">
                    <a href="{{url}}" class="sb-overlay-link">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Explore
                    </a>
                </div>
            </div>
            <div class="sb-card-content">
                <h3>{{title}}</h3>
                <p class="sb-card-desc">{{custom_excerpt}}</p>
                <div class="sb-card-footer">
                    <a href="{{url}}" class="sb-download-btn">
                        Explore Resource
                    </a>
                </div>
            </div>
        </div>
        {{/foreach}}
        {{else}}
        {{!-- Fallback to original content --}}
        <!-- Rain Bingo -->
        <div class="sb-card">
            <div class="sb-card-img">
                <img src="{{asset 'sb/Rain Bingo.png'}}" alt="Rain Bingo">
                <div class="sb-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Rain BIngo Kannada.pdf'}}"
                        class="sb-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="sb-card-content">
                <h3>Rain Bingo</h3>
                <p class="sb-card-desc">Explore the wonders that arrive with the rains — from fungi to frogs, discover
                    monsoon magic around you.</p>
                <div class="sb-card-footer">
                    <div class="sb-download-dropdown">
                        <button class="sb-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="sb-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Rain BIngo Kannada.pdf'}}"
                                class="sb-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Rain BIngo Kannada.pdf'}}"
                                class="sb-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Winter Bingo -->
        <div class="sb-card">
            <div class="sb-card-img">
                <img src="{{asset 'sb/Winter Bingo.png'}}" alt="Winter Bingo">
                <div class="sb-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Winter Bingo Kannada.pdf'}}"
                        class="sb-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="sb-card-content">
                <h3>Winter Bingo</h3>
                <p class="sb-card-desc">Spot the signs of winter — migratory birds, misty mornings, and the quiet beauty
                    of the cold season.</p>
                <div class="sb-card-footer">
                    <div class="sb-download-dropdown">
                        <button class="sb-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="sb-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Winter Bingo Kannada.pdf'}}"
                                class="sb-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Winter Bingo Kannada.pdf'}}"
                                class="sb-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Spring Bingo -->
        <div class="sb-card">
            <div class="sb-card-img">
                <img src="{{asset 'sb/Spring Bingo.png'}}" alt="Kashmir Spring Bingo">
                <div class="sb-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Spring Bingo.pdf'}}"
                        class="sb-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="sb-card-content">
                <h3>Spring Bingo — Kashmir</h3>
                <p class="sb-card-desc">Celebrate the blossoming of Kashmir's spring — fresh blooms, returning birds,
                    and new life everywhere.</p>
                <div class="sb-card-footer">
                    <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Spring Bingo.pdf'}}"
                        class="sb-download-btn" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Resource
                    </a>
                </div>
            </div>
        </div>

        <!-- Summer Bingo -->
        <div class="sb-card">
            <div class="sb-card-img">
                <img src="{{asset 'sb/Summer Bingo.png'}}" alt="Summer Bingo">
                <div class="sb-card-overlay">
                    <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Summer Bingo Kannada.pdf'}}"
                        class="sb-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="sb-card-content">
                <h3>Summer Bingo</h3>
                <p class="sb-card-desc">Feel the heat and find its traces in nature — soaring raptors, blooming trees,
                    and scorching skies.</p>
                <div class="sb-card-footer">
                    <div class="sb-download-dropdown">
                        <button class="sb-download-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="sb-dropdown-menu">
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Summer Bingo Kannada.pdf'}}"
                                class="sb-dropdown-item">English</a>
                            <a href="{{asset 'files/Resources/Bingos/Seasonal Bingos/Kannada/Summer Bingo Kannada.pdf'}}"
                                class="sb-dropdown-item">ಕನ್ನಡ</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/get}}
    </div>

    <!-- Educator Note Section -->
    <section class="sb-educator-note-section">
        <div class="container">
            <div class="sb-educator-note-card">
                <div class="sb-educator-note-header">
                    <div class="sb-educator-icon">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                    </div>
                    <h2 class="sb-educator-title">Note for Educators</h2>
                </div>
                <div class="sb-educator-content">
                    <p>This activity is a fun way to encourage repeated observation of the same environment throughout
                        the year, helping students notice how plants, animals, and their associations respond to
                        seasonal shifts. Use the below observation sheet to take your observations a step further, and
                        log and monitor seasonal changes in the plants and trees around you. Visit <a
                            href="http://www.seasonwatch.in/">www.seasonwatch.in</a> to explore resources, activities
                        and data on some of the most common and widespread trees around you!</p>
                </div>
                <div class="sb-educator-questions">
                    <span class="sb-questions-title">Questions to Explore</span>
                    <ul class="sb-questions-list">
                        <li>What new things did they notice about the season?</li>
                        <li>Why do you think these changes occur in relation to the season?</li>
                        <li>Why do mushrooms pop up after rain? What causes the 'petrichor' smell?</li>
                        <li>Why is there a large blooming of flowers and new leaves during spring?</li>
                        <li>Why do birds like Black Kites circle overhead during hot days?</li>
                        <li>Why does the sun set early during winter?</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    </div>
    {{/post}}