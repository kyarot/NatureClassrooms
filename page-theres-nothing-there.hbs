{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}

    {{#post}} <main class="site-main">
        {{!-- 1. Hero Banner --}}
        <section class="resources-hero" style="text-align: left; justify-content: flex-start;">
            <div class="resources-hero-bg" style="background-image: url('{{asset "carousel/2.jpg"}}');"></div>
            <div class="resources-hero-overlay"></div>
            <div class="container" style="z-index: 3; position: relative; width: 100%;">
            <div class="resources-hero-content"style="margin-left: 0; padding-left: 0; text-align: left;">
                <h1 class="resources-hero-title" style="color: white;" data-reveal>There's Nothing There</h1>
                <p class="resources-hero-subtitle" style="margin-left: 0;" data-reveal>
                    Nature Classrooms’ nature learning book ‘There’s Nothing There!’ follows Arali and her Amma’s
                    journey
                    from her school to their home, and everything that they see (or maybe don’t) in between.
                </p>
            </div>
            </div>
        </section>

        {{!-- 2. Resource Grid --}}
        <section class="site-section">
            <div class="container">
                {{!-- 3. Resource Grid --}}
                <div class="resource-item-grid">
                    {{!-- English & Kannada --}}
                    {{> "resource-item"
                    title="There's Nothing There - English & Kannada"
                    description="This visually stunning bilingual book follows Arali's journey and was inspired by
                    younglings exploring nature in government schools."
                    preview_image=(asset "carousel/1.jpg")
                    download_url="#"
                    lang1="English"
                    lang2="Kannada"
                    }}

                    {{!-- English & Hindi --}}
                    {{> "resource-item"
                    title="There's Nothing There - English & Hindi"
                    description="Join Arali and Amma in this delightful journey through peri-urban landscapes,
                    discovering
                    that there's always nature to be found."
                    preview_image=(asset "carousel/2.jpg")
                    download_url="#"
                    lang1="English"
                    lang2="Hindi"
                    }}
                </div>
            </div>
        </section>

        {{!-- 4. Educator Note Section --}}
        <section class="educator-note-section">
            <div class="container">
                <div class="educator-note-card" data-reveal>
                    <div class="educator-note-header">
                        <div class="educator-icon">
                            <i class="fas fa-search"></i>
                        </div>
                        <h2 class="educator-title">Note for Educators</h2>
                    </div>
                    <div class="educator-content">
                        <p>
                            "There's Nothing There!" is a powerful starting point for challenging the perception of
                            'empty'
                            spaces.
                            Use this module to encourage students to look closer at urban lots, soil, and the air. It
                            works
                            perfectly as both a classroom story session and as 'nature homework' that directs students
                            to
                            observe
                            the often-overlooked biodiversity in their own neighborhoods and school grounds.
                        </p>
                    </div>
                    <div class="educator-questions">
                        <span class="questions-title">Questions to Explore</span>
                        <ul class="questions-list">
                            <li>Why do we often think of urban spaces as 'empty' of nature?</li>
                            <li>What 'surprising' life forms did you find in a lot or in the soil?</li>
                            <li>How does the nature we discovered coexist with the city around it?</li>
                            <li>How can we protect these small pockets of nature in our streets?</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Scroll Reveal
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('[data-reveal]').forEach(el => {
                observer.observe(el);
            });

            // Dynamic Navbar Color Switching
            const header = document.getElementById('siteHeader');
            const hero = document.querySelector('.resources-hero');
            const logoContainer = document.getElementById('floatingLogo');
            const logoImg = document.getElementById('floatingLogoImg');

            function updateNavbar() {
                if (!hero || !header) return;

                const scrollY = window.pageYOffset;
                const heroHeight = hero.offsetHeight;

                if (scrollY < heroHeight - 80) {
                    header.classList.remove('navbar-light');
                    header.classList.add('navbar-dark');
                    if (logoContainer) logoContainer.classList.remove('logo-dark');
                    if (logoImg && window.whiteLogo) logoImg.src = window.whiteLogo;
                } else {
                    header.classList.add('navbar-light');
                    header.classList.remove('navbar-dark');
                    if (logoContainer) logoContainer.classList.add('logo-dark');
                    if (logoImg && window.blackLogo) logoImg.src = window.blackLogo;
                }

                if (scrollY > 100) {
                    header.classList.add('navbar-scrolled');
                } else {
                    header.classList.remove('navbar-scrolled');
                }
            }

            window.addEventListener('scroll', updateNavbar, { passive: true });
            updateNavbar();
        });
    </script>
    {{/post}}