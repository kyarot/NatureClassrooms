{{!< default}} {{#post}} {{#has slug="all-posts" }} <!-- ALL POSTS PAGE -->
    <section class="post-section all-posts-page site-section">
        <div class="container">
            <div class="section-header">
                <h1 class="section-title">{{title}}</h1>
            </div>

            {{#get "posts" limit="100" include="tags,authors"}}
            {{#if posts}}
            <div class="post-grid">
                {{#foreach posts}}
                <article class="post-card {{post_class}}">
                    <a href="{{url}}" class="post-card-link">
                        {{#if feature_image}}
                        <div class="post-card-image" style="background-image: url('{{feature_image}}');"></div>
                        {{else}}
                        <div class="post-card-image post-card-no-image"></div>
                        {{/if}}

                        <div class="post-card-overlay"></div>

                        <div class="post-card-content">
                            {{#if tags}}
                            <div class="post-card-tags">
                                {{#foreach tags limit="2"}}
                                <span class="post-card-tag" {{#if
                                    accent_color}}style="background-color: {{accent_color}};" {{/if}}>{{name}}</span>
                                {{/foreach}}
                            </div>
                            {{/if}}
                            <h2 class="post-card-title">{{title}}</h2>
                            <p class="post-card-excerpt">{{excerpt words="12"}}</p>
                        </div>
                    </a>
                </article>
                {{/foreach}}
            </div>
            {{else}}
            <div class="no-posts">
                <div class="no-posts-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                </div>
                <h3 class="no-posts-title">No posts yet</h3>
                <p class="no-posts-message">New content coming soon. Stay tuned!</p>
            </div>
            {{/if}}
            {{/get}}
        </div>
    </section>

    {{else}}
    {{#has slug="all-tags"}}
    <!-- ALL TAGS PAGE -->
    <section class="all-tags-page site-section">
        <div class="container">
            <header class="all-tags-header">
                <h1 class="all-tags-title">All Topics</h1>
                <p class="all-tags-subtitle">Browse all topics and discover content that interests you</p>
            </header>

            {{#get "tags" include="count.posts" limit="100"}}
            {{#if tags}}
            <div class="tags-grid">
                {{#foreach tags}}
                {{#if count.posts}}
                <a href="{{url}}" class="tag-card">
                    {{#if feature_image}}
                    <div class="tag-card-bg" style="background-image: url('{{feature_image}}');"></div>
                    {{else}}
                    <div class="tag-card-bg tag-card-no-image" {{#if
                        accent_color}}style="background-color: {{accent_color}};" {{/if}}></div>
                    {{/if}}
                    <div class="tag-card-overlay"></div>
                    <div class="tag-card-content">
                        <h3 class="tag-card-name">{{name}}</h3>
                        <span class="tag-card-count">{{count.posts}} {{#if count.posts}}post{{#unless
                            count.posts}}s{{/unless}}{{/if}}</span>
                        {{#if description}}
                        <p class="tag-card-description">{{description}}</p>
                        {{/if}}
                    </div>
                </a>
                {{/if}}
                {{/foreach}}
            </div>
            {{else}}
            <div class="no-tags">
                <p>No topics available yet.</p>
            </div>
            {{/if}}
            {{/get}}
        </div>
    </section>

    {{else}}
    <!-- REGULAR PAGE -->
    <article class="page-article site-section {{post_class}}">
        <div class="container">
            {{#if @page.show_title_and_feature_image}}
            <header class="page-header">
                <h1>{{title}}</h1>

                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
            </header>
            {{/if}}

            <section class="page-content">
                {{content}}
            </section>
        </div>
    </article>
    {{/has}}
    {{/has}}
    {{/post}}