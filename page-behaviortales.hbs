{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}
    {{#post}}
    <div class="behavior-tales-page">

        <!-- Hero Section -->
        <section class="bt-hero">
            <div class="bt-hero-content">
                <div class="bt-hero-subtitle">Nature Classrooms</div>
                <h1>{{title}}</h1>
                <p>{{custom_excerpt}}</p>
            </div>
        </section>

        {{#if content}}
        <div class="ghost-content" style="margin-top: 2rem;">
            {{content}}
        </div>
        {{/if}}

        <!-- Section Header -->
        <div class="bt-section-header">
            <div class="bt-section-title">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path>
                    <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                    <line x1="9" y1="9" x2="9.01" y2="9"></line>
                    <line x1="15" y1="9" x2="15.01" y2="9"></line>
                </svg>
                Resources
            </div>
            <div class="bt-section-line"></div>
        </div>

        <!-- Content Section -->
        <div class="bt-grid">
            {{#get "posts" filter="tag:hash-hash-behavior-tales" order="published_at asc" include="tags"}}
            {{#foreach posts}}
            <div class="bt-card">
                <div class="bt-card-img">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{/if}}
                    <div class="bt-card-overlay">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="bt-overlay-link">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="7 10 12 15 17 10"></polyline>
                                <line x1="12" y1="15" x2="12" y2="3"></line>
                            </svg>
                            Explore
                        </a>
                    </div>
                </div>
                <div class="bt-card-content">
                    <h3>{{title}}</h3>
                    <p class="bt-card-desc">{{custom_excerpt}}</p>
                    <div class="bt-card-footer resource-item-footer" data-custom-link="{{meta_description}}">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="bt-download-btn explore-btn">
                            Learn More
                        </a>
                        <div class="dynamic-download-container" style="display: none;">
                            <div class="download-dropdown">
                                <button class="download-dropdown-btn">
                                    <span>Download</span>
                                    <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </button>
                                <div class="dropdown-menu dynamic-menu">
                                    <!-- Filled via JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </div>

        <!-- Educator Note Section -->
        {{#get "posts" filter="tag:hash-sec-behaviortales-note" limit="1"}}
        {{#foreach posts}}
        <section class="bt-educator-note-section">
            <div class="container">
                <div class="bt-educator-note-card">
                    <div class="bt-educator-note-header">
                        <div class="bt-educator-icon">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                            </svg>
                        </div>
                        <h2 class="bt-educator-title">{{title}}</h2>
                    </div>
                    <div class="bt-educator-content">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

    </div>
    {{/post}}