{{!< default}} {{#post}} <div class="nbsel-page">

    <!-- Hero Section -->
    <section class="nbsel-hero">
        <h1>{{title}}</h1>
    </section>

    <!-- About Section -->
    <section class="nbsel-about-section">
        <div class="nbsel-about-card">
            <div class="nbsel-about-content">
                {{content}}
            </div>
        </div>
    </section>

    <!-- Pilot Workshop Section -->
    <section class="nbsel-workshop-section">
        <div class="nbsel-workshop-container">
            <h2 class="nbsel-workshop-title">Pilot Workshop</h2>
            <p class="nbsel-workshop-desc">With the initial framework and practices developed, we launched an online
                pilot workshop with a goal to engage with a small focus group of teachers/educators, for trialling out
                the initially developed practices and taking into consideration their feedback and responses which will
                influence the future implementation of the programme.</p>

            <div class="nbsel-workshop-images">
                <div class="nbsel-workshop-image">
                    <img src="{{asset 'nbsel/image copy.png'}}" alt="Pilot Workshop Session 2">
                </div>
                <div class="nbsel-workshop-image">
                    <img src="{{asset 'nbsel/image.png'}}" alt="SEL Session 2">
                </div>
            </div>
        </div>
    </section>

    <!-- Download Section -->
    <section class="nbsel-download-section">
        <div class="nbsel-download-card">
            <div class="nbsel-download-info">
                <h3 class="nbsel-download-title">Download Report</h3>
                <div class="nbsel-download-buttons">
                    <a href="{{asset 'files/Our Work/Research/NATURE-BASED SOCIAL-EMOTIONAL LEARNING (SEL) Pilot Report.pdf'}}"
                        class="nbsel-download-btn" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Report
                    </a>
                    <a href="{{asset 'files/Our Work/Research/MASTER_S THESIS.pdf'}}"
                        class="nbsel-download-btn nbsel-download-btn-outline" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Internship Report
                    </a>
                </div>
                <p class="nbsel-download-credit">This project was undertaken by Priyanka Prakash as a part of her
                    Master's internship with Nature Classrooms.</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section class="nbsel-contact-section">
        <div class="nbsel-contact-card">
            <p>Connect if you want to collaborate with us for a research project: <a
                    href="mailto:info@natureclassrooms.in">info@natureclassrooms.in</a></p>
        </div>
    </section>

    <!-- Back to Projects -->
    <section class="nbsel-explore-more">
        <a href="/" class="nbsel-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}