{{!< default}} {{#post}} <div class="nbsel-page">

    <!-- Hero Section -->
    <section class="nbsel-hero">
        <h1>{{title}}</h1>
        <div class="nbsel-hero-subtitle">{{content}}</div>
    </section>

    <!-- About Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-nbsel-about" limit="1"}}
    {{#foreach posts}}
    <section class="nbsel-about-section">
        <div class="nbsel-about-card">
            <div class="nbsel-about-content resource-item-desc">
                {{content}}
            </div>
            <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                style="margin-top: 20px;">
                <div class="dynamic-download-container" style="display: none;">
                    <div class="download-dropdown">
                        <button class="download-dropdown-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="dropdown-menu dynamic-menu"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}


    <!-- Pilot Workshop Section -->
    <section class="nbsel-workshop-section">
        <div class="nbsel-workshop-container">
            <h2 class="nbsel-workshop-title">Pilot Workshop</h2>
            <p class="nbsel-workshop-desc">With the initial framework and practices developed, we launched an online
                pilot workshop with a goal to engage with a small focus group of teachers/educators, for trialling out
                the initially developed practices and taking into consideration their feedback and responses which will
                influence the future implementation of the programme.</p>

            <div class="nbsel-workshop-images">
                <div class="nbsel-workshop-image">
                    <img src="{{asset 'images/img3.png'}}" alt="Pilot Workshop Session 2">
                </div>
                <div class="nbsel-workshop-image">
                    <img src="{{asset 'images/img4.png'}}" alt="SEL Session 2">
                </div>
            </div>
        </div>
    </section>

    <!-- Download Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-nbsel-download" limit="1"}}
    {{#foreach posts}}
    <section class="nbsel-download-section">
        <div class="nbsel-download-card">
            <div class="nbsel-download-info">
                <h3 class="nbsel-download-title">{{title}}</h3>
                <div class="nbsel-download-content resource-item-desc">
                    {{content}}
                </div>
                <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                    style="margin-top: 20px;">
                    <div class="dynamic-download-container" style="display: none;">
                        <div class="download-dropdown">
                            <button class="download-dropdown-btn">
                                <span>Download Report</span>
                                <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="dropdown-menu dynamic-menu"></div>
                        </div>
                    </div>
                </div>
                {{#if custom_excerpt}}
                <p class="nbsel-download-credit">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{else}}
    {{!-- Fallback if no post is found --}}
    <section class="nbsel-download-section">
        <div class="nbsel-download-card">
            <div class="nbsel-download-info">
                <h3 class="nbsel-download-title">Download Report</h3>
                <p class="nbsel-download-credit">No report available for download yet.</p>
            </div>
        </div>
    </section>
    {{/get}}

    <!-- Contact Section -->
    <section class="nbsel-contact-section">
        <div class="nbsel-contact-card">
            <p>Connect if you want to collaborate with us for a research project: <a
                    href="mailto:info@natureclassrooms.in">info@natureclassrooms.in</a></p>
        </div>
    </section>

    <!-- Back to Projects -->
    <section class="nbsel-explore-more">
        <a href="/" class="nbsel-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}