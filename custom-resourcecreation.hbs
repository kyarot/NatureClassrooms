{{!< default}} {{#post}} <div class="rc-page">
    {{!-- 1. Hero Section --}}
    <section class="rc-hero" style="background-image: url('{{#if feature_image}}{{feature_image}}{{else}}{{asset "
        resourcecreation/res3.JPG"}}{{/if}}');">
        <div class="rc-hero-content">
            <div class="rc-hero-subtitle">Nature Classrooms</div>
            <h1>{{title}}</h1>
        </div>
    </section>

    {{!-- 2. Hero Content / Intro --}}
    {{#if content}}
    <section class="rc-dynamic-content">
        <div class="rc-intro">
            {{content}}
        </div>
    </section>
    {{/if}}

    {{!-- 3. Additional Intro (from post) --}}
    {{#get "posts" filter="tag:hash-sec-rc-intro" limit="1"}}
    {{#foreach posts}}
    <section class="rc-intro">
        {{content}}
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- 4. Inspiring Students --}}
    {{#get "posts" filter="tag:hash-sec-rc-inspiring" limit="1"}}
    {{#foreach posts}}
    <section class="rc-inspiring">
        <h2>{{title}}</h2>
        <div class="inspiring-intro-text">
            {{content}}
        </div>

        <div class="inspiring-grid">
            {{#get "posts" limit="100" filter="tag:hash-card-rc-inspiring" order="published_at asc"}}
            {{#foreach posts}}
            <div class="inspiring-card">
                <div class="ic-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        {{#if meta_description}}
                        {{{meta_description}}}
                        {{else}}
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M2 12c0 0 5-8 10-8s10 8 10 8-5 8-10 8-10-8-10-8z"></path>
                        {{/if}}
                    </svg>
                </div>
                {{content}}
            </div>
            {{/foreach}}
            {{/get}}
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- 5. Featured Projects & Additional Content --}}
    {{#get "posts" filter="tag:hash-sec-rc-featured" order="published_at asc"}}
    {{#foreach posts}}
    <section class="rc-featured">
        <div class="featured-container">
            <div class="featured-content">
                <div class="featured-label">Featured Project</div>
                <h2>{{title}}</h2>
                {{content}}
                {{#if meta_description}}
                <a href="{{meta_description}}" class="btn-read-more">Read More →</a>
                {{/if}}
            </div>
            <div class="featured-image">
                {{#if feature_image}}
                <img src="{{feature_image}}" alt="{{title}}">
                {{/if}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- 6. Explore More --}}
    {{#get "posts" filter="tag:hash-sec-rc-explore" order="published_at asc"}}
    {{#foreach posts}}
    <section class="rc-explore">
        <div class="explore-image">
            {{#if feature_image}}
            <img src="{{feature_image}}" alt="{{title}}" style="height: 400px; width: 100%; object-fit: cover;">
            {{/if}}
        </div>
        <div class="explore-content">
            <h2>{{title}}</h2>
            {{content}}
            {{#if meta_description}}
            <a href="{{meta_description}}" class="btn-browse">Browse Resources →</a>
            {{/if}}
        </div>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- 7. Bottom Collaboration Section --}}
    {{#get "posts" filter="tag:hash-sec-rc-collab" limit="1"}}
    {{#foreach posts}}
    <section class="rc-collab-section">
        <div class="collab-box">
            <div class="collab-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
            </div>
            <div class="collab-details">
                <h4>{{title}}</h4>
                {{content}}
                {{#if meta_description}}
                <div style="margin-top: 10px;">
                    <a href="{{meta_description}}"
                        style="color: var(--nc-green); font-weight: 600; text-decoration: none;">Get in touch →</a>
                </div>
                {{/if}}
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}
    </div>
    {{/post}}