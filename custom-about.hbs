{{!< default}} {{#post}} <div class="about-page">
    {{!-- Hero Section (Source: Page) --}}
    <section class="about-hero"
        style="background-image: url('{{#if feature_image}}{{img_url feature_image}}{{else}}{{asset "
        about/about.jpeg"}}{{/if}}');">
        <div class="about-hero-content">
            <br><br>
            <h1 style="color: white;">{{title}}</h1>
        </div>
    </section>

    {{#if content}}
    <section class="about-dynamic-content">
        <div class="container" style="padding: 100px 20px;">
            {{content}}
        </div>
    </section>
    {{/if}}

    {{!-- Intro Section (Post #sec-about-intro) --}}
    {{#get "posts" filter="tag:hash-sec-about-intro" limit="1"}}
    {{#foreach posts}}
    <section class="about-intro">
        <div class="about-intro-content">
            <div class="section-line"></div>
            {{content}}
        </div>

        {{#if feature_image}}
        <div class="about-intro-image-container">
            <div class="image-decorative-frame"></div>
            <div class="about-intro-image">
                <img src="{{img_url feature_image}}" alt="{{title}}">
                {{#if custom_excerpt}}
                <div class="about-founded-badge">
                    <h3>{{custom_excerpt}}</h3>
                    <p>Founded</p>
                </div>
                {{/if}}
            </div>
        </div>
        {{/if}}
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- Vision Section (Post #sec-about-vision) --}}
    {{#get "posts" filter="tag:hash-sec-about-vision" limit="1"}}
    {{#foreach posts}}
    <section class="about-vision" id="vision" {{#if
        feature_image}}style="background-image: url('{{img_url feature_image}}');" {{/if}}>
        <h2 style="color: white;">{{title}}</h2>
        <blockquote class="about-vision-quote">
            {{content}}
        </blockquote>
    </section>
    {{/foreach}}
    {{/get}}

    {{!-- Goals Section (Post #sec-about-goals-title + cards #card-about-goal) --}}
    <section class="about-goals">
        <div class="about-goals-header">
            <div class="vertical-line"></div>
            {{#get "posts" filter="tag:hash-sec-about-goals-title" limit="1"}}
            {{#foreach posts}}
            <h2>{{title}}</h2>
            {{/foreach}}
            {{else}}
            <h2>Our Goals</h2>
            {{/get}}
        </div>

        <div class="about-goals-grid">
            {{#get "posts" filter="tag:hash-card-about-goal" order="published_at asc" limit="100"}}
            {{#foreach posts}}
            <div class="goal-card">
                {{content}}
            </div>
            {{/foreach}}
            {{/get}}
        </div>
    </section>

    {{!-- Team Section (Posts #team-member) --}}
    <section class="team-section" id="team">
        <div class="team-header">
            <h2>Meet the team</h2>
        </div>

        <div class="team-loop-container">
            <div class="team-track">
                {{!-- Set 1 --}}
                {{#get "posts" limit="100" filter="tag:hash-team-member" include="tags,authors" visibility="all" order="published_at asc"}}
                {{#foreach posts}}
                <div class="team-card">
                    {{#if feature_image}}
                    <img src="{{img_url feature_image}}" alt="{{title}}" class="team-card-image">
                    {{/if}}
                    <div class="team-info">
                        <div class="team-header-info">
                            <h3>{{title}}</h3>
                            <span class="role">{{primary_tag.name}}</span>
                        </div>
                        <div class="team-bio">
                            {{content}}
                            {{#if meta_description}}
                            <a href="{{meta_description}}" target="_blank" rel="noopener noreferrer" class="team-link"
                                style="color: #fff;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <path
                                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                    <rect x="2" y="9" width="4" height="12" />
                                    <circle cx="4" cy="4" r="2" />
                                </svg>
                            </a>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}

                {{!-- Duplicate Set for Seamless Loop --}}
                {{#get "posts" limit="100" filter="tag:hash-team-member" include="tags,authors" visibility="all" order="published_at asc"}}
                {{#foreach posts}}
                <div class="team-card">
                    {{#if feature_image}}
                    <img src="{{img_url feature_image}}" alt="{{title}}" class="team-card-image">
                    {{/if}}
                    <div class="team-info">
                        <div class="team-header-info">
                            <h3>{{title}}</h3>
                            <span class="role">{{primary_tag.name}}</span>
                        </div>
                        <div class="team-bio">
                            {{content}}
                            {{#if meta_description}}
                            <a href="{{meta_description}}" target="_blank" rel="noopener noreferrer" class="team-link"
                                style="color: #fff;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                    stroke-linecap="round" stroke-linejoin="round">
                                    <path
                                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                    <rect x="2" y="9" width="4" height="12" />
                                    <circle cx="4" cy="4" r="2" />
                                </svg>
                            </a>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Team Member Modal --}}
    <div class="team-modal-overlay" id="teamModal">
        <div class="team-modal">
            <button class="team-modal-close">&times;</button>
            <div class="team-modal-content">
                <img class="team-modal-image" src="" alt="">
                <div class="team-modal-info">
                    <h3 class="team-modal-name"></h3>
                    <span class="team-modal-role"></span>
                    <div class="team-modal-bio"></div>
                </div>
            </div>
        </div>
    </div>

    {{!-- Alumni & Interns Section --}}
    <section class="alumni-interns-section">
        <div class="container grid-2">
            <div class="alumni-col">
                <div class="section-subtitle">
                    <span class="subtitle-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </span>
                    <h2>Alumni</h2>
                </div>
                <div class="alumni-list">
                    {{#get "posts" filter="tag:hash-card-about-alumni" order="published_at asc" limit="100"}}
                    {{#foreach posts}}
                    <div class="alumni-card">
                        <div class="alumni-initials">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}NC{{/if}}</div>
                        <span class="alumni-name">{{title}}</span>
                        {{#if meta_description}}
                        <a href="{{meta_description}}" class="linkedin-icon" target="_blank" rel="noopener noreferrer">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path
                                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                <rect x="2" y="9" width="4" height="12" />
                                <circle cx="4" cy="4" r="2" />
                            </svg>
                        </a>
                        {{/if}}
                    </div>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>

            <div class="interns-col">
                <div class="section-subtitle">
                    <span class="subtitle-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </span>
                    <h2>Interns</h2>
                </div>
                <div class="alumni-list">
                    {{#get "posts" filter="tag:hash-card-about-intern" order="published_at asc" limit="100"}}
                    {{#foreach posts}}
                    <div class="alumni-card">
                        <div class="alumni-initials gold">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}NC{{/if}}
                        </div>
                        <span class="alumni-name">{{title}}</span>
                        {{#if meta_description}}
                        <a href="{{meta_description}}" class="linkedin-icon" target="_blank" rel="noopener noreferrer">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path
                                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                <rect x="2" y="9" width="4" height="12" />
                                <circle cx="4" cy="4" r="2" />
                            </svg>
                        </a>
                        {{/if}}
                    </div>
                    {{/foreach}}
                    {{/get}}
                </div>
            </div>
        </div>
    </section>

    {{!-- Illustrators Section --}}
    <section class="illustrators-section">
        <div class="container text-center">
            <h2 class="illustrators-title" style="color: white;text-align: center;">Illustrators</h2>
            <p class="illustrators-subtitle" style="text-align: center;">The talented artists who bring our resources to
                life</p>

            <div class="illustrators-pills">
                {{#get "posts" filter="tag:hash-card-about-illustrator" order="published_at asc" limit="100"}}
                {{#foreach posts}}
                <a href="{{#if meta_description}}{{meta_description}}{{else}}#{{/if}}" class="illustrator-pill"
                    target="_blank" rel="noopener noreferrer">
                    {{title}}
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" />
                    </svg>
                </a>
                {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- Learn More / CTA Section --}}
    {{#get "posts" filter="tag:hash-sec-about-cta" limit="1"}}
    {{#foreach posts}}
    <section class="about-cta-section">
        <div class="container text-center">
            <h2 class="cta-title" style="text-align: center;">{{title}}</h2>
            <div class="cta-subtitle-dynamic"
                style="text-align: center; color: rgba(255,255,255,0.8); margin-bottom: 30px;">
                {{content}}
            </div>
            {{#if meta_description}}
            <div class="cta-buttons">
                <a href="{{meta_description}}" class="btn btn-primary">Learn More</a>
            </div>
            {{/if}}
        </div>
    </section>
    {{/foreach}}
    {{else}}
    <section class="about-cta-section">
        <div class="container text-center">
            <h2 class="cta-title" style="text-align: center;">Want to Learn More?</h2>
            <p class="cta-subtitle" style="text-align: center;">Explore our work, resources, and how we're transforming
                nature education across India.</p>
            <div class="cta-buttons">
                <a href="/our-approach/" class="btn btn-primary">Our Work</a>
                <a href="/media/" class="btn btn-outline">NC in Media</a>
            </div>
        </div>
    </section>
    {{/get}}
    </div>
    {{/post}}