{{!< default}} <div class="about-page">

    {{#post}}
    <!-- Hero Section -->
    <section class="about-hero" style="background-image: url('{{asset 'about/hop.jpg'}}');">
        <div class="about-hero-content">
            <span class="about-hero-tag">Who We Are</span>
            <h1>Rooted in Nature,<br><span>Growing</span> Through Education</h1>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="about-intro">
        <div class="about-intro-content">
            <div class="section-line"></div>
            <h2>Connecting Learning to the <span>Natural World</span></h2>
            <p>Nature Classrooms works with teachers, schools and educators to connect meaningful, age-appropriate and
                locally-culturally relevant nature learning with the EVS curriculum being taught in teaching-learning
                spaces in India.</p>
            <p>Nature Classrooms started as an initiative within Nature Conservation Foundation's Education and Public
                Engagement Programme in November 2018.</p>

            <div class="about-collaboration-box">
                <p>Since April 2025, Nature Classrooms works in collaboration with the <strong>Youth for Conservation
                        Action Network (YouCAN)</strong> to effectively advance our individual and collective goals for
                    nature education and conservation.</p>
            </div>
        </div>

        <div class="about-intro-image-container">
            <div class="image-decorative-frame"></div>
            <div class="about-intro-image">
                <img src="{{asset 'about/hop.jpg'}}" alt="Nature Pattern">
                <div class="about-founded-badge">
                    <h3>2018</h3>
                    <p>Founded</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Vision Section -->
    <section class="about-vision">
        <div class="vision-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <h2>Our Vision</h2>
        <blockquote class="about-vision-quote">
            "Bringing nature learning to everyday education with a hope to spark and rekindle wonder, curiosity, empathy
            and love for our Natural World."
        </blockquote>
        <div class="vision-dots">
            <span></span><span class="active"></span><span></span><span></span><span></span><span></span><span></span>
        </div>
    </section>

    <!-- Goals Section -->
    <section class="about-goals">
        <div class="about-goals-header">
            <div class="vertical-line"></div>
            <span>Our Goals</span>
            <h2>What Drives Us Forward</h2>
        </div>

        <div class="about-goals-grid">
            <div class="goal-card">
                <div class="goal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" />
                        <circle cx="12" cy="12" r="6" />
                        <circle cx="12" cy="12" r="2" />
                    </svg>
                </div>
                <h3>Contextual Learning</h3>
                <p>Introducing, designing and connecting contextual and meaningful nature learning to education, by
                    working with teaching-learning communities.</p>
            </div>

            <div class="goal-card">
                <div class="goal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                        <circle cx="12" cy="12" r="3" />
                    </svg>
                </div>
                <h3>Shift Perspectives</h3>
                <p>Our framework guides a shift from a human-centric and purely utilitarian perspective to one that
                    emphasizes wonder, curiosity, inquiry and interconnectedness.</p>
            </div>

            <div class="goal-card">
                <div class="goal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                    </svg>
                </div>
                <h3>Relevant Resources</h3>
                <p>Developing age-appropriate and locally-culturally relevant nature-based teaching-learning resources
                    linked with the school curriculum.</p>
            </div>

            <div class="goal-card">
                <div class="goal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </div>
                <h3>Capacity Building</h3>
                <p>Collaborative capacity-building training programmes and workshops on ecology, nature learning and
                    conservation education.</p>
            </div>

            <div class="goal-card">
                <div class="goal-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="M4.7 19h14.6L12 4z" />
                        <path d="M9 19V9l3-2 3 2v10" />
                    </svg>
                </div>
                <h3>Research & Practice</h3>
                <p>Designing and contributing to topical research questions in nature education for practitioners in the
                    global south.</p>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="team-section">
        <div class="team-header">
            <h2>Meet the team <span class="header-arrow">→</span></h2>
        </div>

        <div class="team-grid">
            <!-- Vena Kapoor -->
            <div class="team-card" data-initials="VK">
                <div class="team-badge-container">
                    <div class="team-badge">VK</div>
                </div>
                <div class="team-info">
                    <h3>Vena Kapoor</h3>
                    <span class="role">Programme Lead & Sr. Scientist</span>
                    <p class="team-bio">Expert in nature education and ecology with years of experience leading
                        conservation initiatives.</p>
                </div>
            </div>

            <!-- Priyanka Prakash -->
            <div class="team-card yellow" data-initials="PP">
                <div class="team-badge-container">
                    <div class="team-badge">PP</div>
                </div>
                <div class="team-info">
                    <h3>Priyanka Prakash</h3>
                    <span class="role">Senior Manager — Education, Training & Research</span>
                    <p class="team-bio">Passionate about teacher training and developing research-based pedagogical
                        frameworks.</p>
                </div>
            </div>

            <!-- Tanaya Rele -->
            <div class="team-card active" data-initials="TR">
                <div class="team-badge-container">
                    <div class="team-badge">TR</div>
                </div>
                <div class="team-info">
                    <h3>Tanaya Rele</h3>
                    <span class="role">Manager — Education Resources, Research & Comms</span>
                    <p class="team-bio">Completed her Master's in Wildlife Conservation Action, focusing on visitor
                        perceptions of urban parks. Currently designing the Nature Education Assessment Framework
                        (NEAF).</p>
                    <a href="#" class="team-link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                            <rect x="2" y="9" width="4" height="12" />
                            <circle cx="4" cy="4" r="2" />
                        </svg> LinkedIn</a>
                </div>
            </div>

            <!-- Aditi Rao -->
            <div class="team-card" data-initials="AR">
                <div class="team-badge-container">
                    <div class="team-badge">AR</div>
                </div>
                <div class="team-info">
                    <h3>Aditi Rao</h3>
                    <span class="role">Manager — Education, Outreach & Comms</span>
                    <p class="team-bio">Connecting communities through impactful outreach and effective nature
                        communication strategies.</p>
                </div>
            </div>

            <!-- Aswathi Asokan -->
            <div class="team-card yellow" data-initials="AA">
                <div class="team-badge-container">
                    <div class="team-badge">AA</div>
                </div>
                <div class="team-info">
                    <h3>Aswathi Asokan</h3>
                    <span class="role">Manager — Curriculum Development, Resources & Training</span>
                    <p class="team-bio">Developing robust curriculum bridges between school requirements and nature
                        learning.</p>
                </div>
            </div>
        </div>
    </section>
    {{/post}}

    </div>