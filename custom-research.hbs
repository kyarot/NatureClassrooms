{{!< default}} <div class="research-page">
    <!-- Hero Section -->
    <header class="research-hero">
        <div class="research-hero-bg"></div>
        <div class="research-hero-overlay"></div>
        <div class="research-hero-content">
            <h1>Research</h1>
            <p>Everything we do is rooted in thoughtful reflection and research.</p>
        </div>
    </header>

    <!-- Core Philosophy Section -->
    <section class="research-philosophy">
        <div class="research-container">
            <div class="philosophy-content">
                <h2>Our Research Approach</h2>
                <p class="lead">
                    We explore how students and teachers experience and connect with the natural world, uncovering
                    stories and insights that guide how we engage with learners.
                </p>
                <p>
                    Through gap analysis, especially in the context of the Global South, we keep our work grounded,
                    contextual, and evolving. Our research aims to inform our own practice and support the wider nature
                    education community in reimagining how everyday nature can be meaningfully and seamlessly woven into
                    teaching–learning spaces.
                </p>
            </div>
        </div>
    </section>

    <!-- Research Projects Section -->
    <section class="research-projects">
        <div class="research-container">
            <!-- NEAF -->
            <div class="project-item alternating">
                <div class="project-image">
                    <img src="{{asset 'research/res2.JPG'}}" alt="Nature Education Assessment Framework">
                </div>
                <div class="project-details">
                    <span class="project-category">Open Source Tool</span>
                    <h3>Nature Education Assessment Framework (NEAF)</h3>
                    <p>
                        Developed with the support of the Inlaks Ravi Sankaran Small Grants Programme as an open-source
                        tool to assess the effectiveness of nature education programmes and other nature learning
                        initiatives.
                    </p>
                    <a href="https://www.natureclassrooms.org/nature-education-assessment-framework"
                        class="read-more-link">Read More</a>
                </div>
            </div>

            <!-- Social-Emotional Learning -->
            <div class="project-item alternating reversed">
                <div class="project-image">
                    <img src="{{asset 'research/res3.jpg'}}" alt="Social-Emotional Learning">
                </div>
                <div class="project-details">
                    <span class="project-category">Educator Programme</span>
                    <h3>Nature-based Social-Emotional Learning</h3>
                    <p>
                        A programme for teachers and educators that integrates nature learning with social-emotional
                        learning, fostering deeper connections and emotional wellbeing through environmental engagement.
                    </p>
                    <a href="https://www.natureclassrooms.org/nature-based-social-emotional-learning"
                        class="read-more-link">Read More</a>
                </div>
            </div>

            <!-- Children and Nature in the City -->
            <div class="project-item alternating">
                <div class="project-image">
                    <img src="{{asset 'research/res4.jpg'}}" alt="Children and Nature in the City">
                </div>
                <div class="project-details">
                    <span class="project-category">Urban Research</span>
                    <h3>Children and Nature in the City</h3>
                    <p>
                        A collaborative research project that explores the city through the lens of children,
                        understanding how nature features in the social life of urban youth and how they navigate their
                        green spaces.
                    </p>
                    <a href="https://www.natureclassrooms.org/children-nature-city" class="read-more-link">Read More</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Quote/Footer Section -->
    <section class="research-footer-cta">
        <div class="research-container">
            <div class="footer-cta-card">
                <h2>Collaboration & Insights</h2>
                <p>Interested in our methodology or looking to collaborate on nature-based research projects?</p>
                <a href="mailto:info@natureclassrooms.in" class="cta-primary">Get in Touch</a>
            </div>
        </div>
    </section>
    </div>