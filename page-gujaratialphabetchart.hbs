{{!< default}}

<div class="gujarati-alphabet-page">

    <!-- Hero Section -->
    <section class="gu-hero">
        <h1>Gujarati Alphabet Chart</h1>
        <p>Walk into any classroom and you'll often find charts featuring exotic animals. But what about the unique life thriving in our own landscapes? Our Gujarati Alphabet Chart celebrates the rich biodiversity of the Surendranagar district in Saurashtra, Gujarat. Featuring names in the Kathiawadi dialect, this resource brings the vast savanna grasslands and thorn forests right into the learning space. Developed collaboratively with pastoralists, botanists, and artists.</p>
    </section>

    <!-- Section Header -->
    <div class="gu-section-header">
        <div class="gu-section-title">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                <line x1="9" y1="7" x2="15" y2="7"></line>
                <line x1="9" y1="11" x2="15" y2="11"></line>
            </svg>
            Resources
        </div>
        <div class="gu-section-line"></div>
        <div class="gu-section-count">4 resources</div>
    </div>

    <!-- Resource Grid -->
    <div class="gu-grid">

        <!-- Gujarati Alphabet Chart -->
        <div class="gu-card">
            <div class="gu-card-img">
                <img src="{{asset 'gj/Preview of Gujarati Alphabet Chart.png'}}" alt="Gujarati Alphabet Chart">
                <div class="gu-card-overlay">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Gujarati Alphabet Chart/Gujarati Alphabet Chart A1.pdf'}}" class="gu-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="gu-card-content">
                <h3>Gujarati Alphabet Chart</h3>
                <p class="gu-card-desc">The complete Gujarati alphabet chart featuring biodiversity from Saurashtra's savanna grasslands and thorn forests.</p>
                <div class="gu-card-footer">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Gujarati Alphabet Chart/Gujarati Alphabet Chart A1.pdf'}}" class="gu-download-btn" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download Resource
                    </a>
                </div>
            </div>
        </div>

        <!-- Activity Sheet 1 -->
        <div class="gu-card">
            <div class="gu-card-img">
                <img src="{{asset 'gj/Preview - Activity Sheet 1.png'}}" alt="Activity Sheet 1">
                <div class="gu-card-overlay">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Gujarati Alphabet Chart/Activity Sheet 1.pdf'}}" class="gu-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Quick Download
                    </a>
                </div>
            </div>
            <div class="gu-card-content">
                <h3>Activity Sheet 1</h3>
                <p class="gu-card-desc">Hands-on activity sheet to complement the Gujarati Alphabet Chart with fun learning exercises.</p>
                <div class="gu-card-footer">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Gujarati Alphabet Chart/Activity Sheet 1.pdf'}}" class="gu-download-btn" download>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Download Resource
                    </a>
                </div>
            </div>
        </div>

        <!-- Activity Sheet 2 -->
        <div class="gu-card">
            <div class="gu-card-img">
                <img src="{{asset 'gj/Preview - Activity Sheet 2.png'}}" alt="Activity Sheet 2">
                <div class="gu-card-overlay">
                    <a href="{{asset 'files/Resources/Alphabet Charts/Gujarati Alphabet Chart/Activity Sheet 2.pdf'}}" class="gu-overlay-link" download>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
