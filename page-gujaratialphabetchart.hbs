{{!< default}} {{#contentFor "styles" }} <link rel="stylesheet" href="{{asset 'css/resources.css'}}">
    {{/contentFor}}
    {{#post}}
    <div class="gujarati-alphabet-page">

        <!-- Hero Section -->
        <section class="gu-hero">
            <h1>{{title}}</h1>
            <div class="gu-hero-content">
                {{#if content}}
                <div class="ghost-content">
                    {{content}}
                </div>
                {{else}}
                <p>{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </section>

        <!-- Section Header -->
        <div class="gu-section-header">
            <div class="gu-section-title">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    <line x1="9" y1="7" x2="15" y2="7"></line>
                    <line x1="9" y1="11" x2="15" y2="11"></line>
                </svg>
                Resources
            </div>
            <div class="gu-section-line"></div>
        </div>

        <!-- Resource Grid -->
        <div class="gu-grid">
            {{#get "posts" filter="tag:hash-hash-gujarati-alphabet" order="published_at asc" include="tags"}}
            {{#foreach posts}}
            <div class="gu-card">
                <div class="gu-card-img">
                    {{#if feature_image}}
                    <img src="{{feature_image}}" alt="{{title}}">
                    {{/if}}
                    <div class="gu-card-overlay">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="gu-overlay-link">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                <polyline points="7 10 12 15 17 10"></polyline>
                                <line x1="12" y1="15" x2="12" y2="3"></line>
                            </svg>
                            Explore
                        </a>
                    </div>
                </div>
                <div class="gu-card-content">
                    <h3>{{title}}</h3>
                    <p class="gu-card-desc">{{custom_excerpt}}</p>
                    <div class="gu-card-footer resource-item-footer" data-custom-link="{{meta_description}}">
                        <a href="{{#if meta_description}}{{meta_description}}{{else}}{{url}}{{/if}}"
                            class="gu-download-btn explore-btn">
                            Explore Resource
                        </a>
                        <div class="dynamic-download-container" style="display: none;">
                            <div class="download-dropdown">
                                <button class="download-dropdown-btn">
                                    <span>Download</span>
                                    <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                        stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <polyline points="6 9 12 15 18 9"></polyline>
                                    </svg>
                                </button>
                                <div class="dropdown-menu dynamic-menu">
                                    <!-- Filled via JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/foreach}}
            {{/get}}
        </div>

        {{#get "posts" filter="tag:hash-sec-gujarati-note" limit="1"}}
        {{#foreach posts}}
        <section class="gu-educator-note-section">
            <div class="container">
                <div class="gu-educator-note-card">
                    <div class="gu-educator-note-header">
                        <div class="gu-educator-icon">
                            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                            </svg>
                        </div>
                        <h2 class="gu-educator-title">{{title}}</h2>
                    </div>
                    <div class="gu-educator-content">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>
        {{/foreach}}
        {{/get}}

        <!-- Explore More Section -->
        <section class="gu-explore-more">
            <a href="/alphabet-charts/" class="gu-explore-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Explore More Alphabet Charts
            </a>
        </section>

    </div>
    {{/post}}