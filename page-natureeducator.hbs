{{!< default}} {{#post}} <div class="nem-page">

    <!-- Hero Section -->
    <section class="nem-hero">
        <h1>{{title}}</h1>
        <div class="nem-hero-subtitle">{{content}}</div>
    </section>

    <!-- About Section (Dynamic) -->
    {{#get "posts" filter="tag:hash-sec-nem-about" limit="1"}}
    {{#foreach posts}}
    <section class="nem-about-section">
        <div class="nem-about-card">
            <div class="nem-about-content resource-item-desc">
                {{content}}
            </div>
            <div class="resource-item-footer" data-custom-link="{{url}}" data-parse-body="true"
                style="margin-top: 20px;">
                <div class="dynamic-download-container" style="display: none;">
                    <div class="download-dropdown">
                        <button class="download-dropdown-btn">
                            <span>Download</span>
                            <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>
                        <div class="dropdown-menu dynamic-menu"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{/foreach}}
    {{/get}}






    <!-- Contact Section -->
    <section class="nem-contact-section">
        <div class="nem-contact-card">
            <div class="nem-contact-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
            </div>
            <p>If you are interested in joining or initiating a chapter in your city or town, reach out to us at <a
                    href="mailto:info@natureclassrooms.in">info@natureclassrooms.in</a></p>
        </div>
    </section>

    <!-- Back to Projects -->
    <section class="nem-explore-more">
        <a href="/" class="nem-explore-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Projects
        </a>
    </section>

    </div>
    {{/post}}