    <link rel="stylesheet" href="{{asset 'css/plant-poster.css'}}">
    <link rel="stylesheet" href="{{asset 'css/behavior-tales.css'}}">
    <link rel="stylesheet" href="{{asset 'css/kashmiri-alphabet.css'}}">
    <link rel="stylesheet" href="{{asset 'css/tamil-alphabet.css'}}">
