    <link rel="stylesheet" href="{{asset 'css/gujarati-alphabet.css'}}">
    <link rel="stylesheet" href="{{asset 'css/water-module.css'}}">
    <link rel="stylesheet" href="{{asset 'css/nature-moves.css'}}">
    <link rel="stylesheet" href="{{asset 'css/nature-strokes.css'}}">
    <link rel="stylesheet" href="{{asset 'css/suttha-muttha.css'}}">
    <link rel="stylesheet" href="{{asset 'css/nature-education-assessment-framework.css'}}">
    <link rel="stylesheet" href="{{asset 'css/nature-based-social-emotional-learning.css'}}">
    <link rel="stylesheet" href="{{asset 'css/children-nature-city.css'}}">
    <link rel="stylesheet" href="{{asset 'css/communities-of-practice.css'}}">
    <link rel="stylesheet" href="{{asset 'css/nature-educator.css'}}">
