<!DOCTYPE html>
<html lang="{{@site.locale}}">

<head>
    <meta charset="utf-8">
    <title>{{meta_title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Oswald:wght@400;500;600;700&family=Playfair+Display:wght@900&family=Poppins:wght@400;600&display=swap"
        rel="stylesheet">

    {{ghost_head}}

    <!-- FIXED CSS PATHS -->
    <link rel="stylesheet" href="{{asset 'css/default.css'}}">
    <link rel="stylesheet" href="{{asset 'css/index.css'}}">
    <link rel="stylesheet" href="{{asset 'css/about.css'}}">
    <link rel="stylesheet" href="{{asset 'css/media.css'}}">
    <link rel="stylesheet" href="{{asset 'css/blog.css'}}">
    <link rel="stylesheet" href="{{asset 'css/resourcecreation.css'}}">
    <link rel="stylesheet" href="{{asset 'css/capacity.css'}}">
    <link rel="stylesheet" href="{{asset 'css/research.css'}}">
    <link rel="stylesheet" href="{{asset 'css/outreach.css'}}">

    {{{block "styles"}}}

</head>

<body class="{{body_class}}">

    <!-- Floating Logo -->
    <div class="floating-logo" id="floatingLogo">
        <a href="/" style="display: block;">
            <img src="{{asset 'logo/main.png'}}" alt="{{@site.title}}" id="floatingLogoImg">
        </a>
    </div>

    {{> header}}

    <main class="site-main">
        {{{body}}}
    </main>

    {{> footer}}

    <script>
        window.whiteLogo = '{{asset "logo/main.png"}}';
        window.blackLogo = '{{asset "logo/blackmain.png"}}';
    </script>

    <!-- FIXED JS PATH -->
    <script src="{{asset 'js/main.js'}}" defer></script>

    {{ghost_foot}}

</body>

</html>