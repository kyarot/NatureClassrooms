    <link rel="stylesheet" href="{{asset 'css/search.css'}}">
    <link rel="stylesheet" href="{{asset 'css/responsive.css'}}">

    {{{block "styles"}}}

</head>

<body class="{{body_class}}">

    <!-- Floating Logo -->
    <div class="floating-logo" id="floatingLogo">
        <a href="/" style="display: block;">
            <img src="{{asset 'logo/main.png'}}" alt="{{@site.title}}" id="floatingLogoImg">
        </a>
    </div>

    {{> header}}

    <main class="site-main">
        {{{body}}}
    </main>

    {{> footer}}

    <script>
        window.whiteLogo = '{{asset "logo/main.png"}}';
        window.blackLogo = '{{asset "logo/blackmain.png"}}';
    </script>

    <!-- FIXED JS PATH -->
    <script src="{{asset 'js/main.js'}}" defer></script>

    <!-- Dynamic Download Parser -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 1. Existing Metadata-based parser (for items using DOWNLOAD: prefix in meta)
            const metadataFooters = document.querySelectorAll('.resource-item-footer[data-custom-link^="DOWNLOAD:"]');
            metadataFooters.forEach(footer => {
                const linkData = footer.getAttribute('data-custom-link');
                const cleanData = linkData.replace('DOWNLOAD:', '').trim();
                const items = cleanData.split(',').map(item => item.trim());
                populateDropdown(footer, items.map(item => {
                    const [label, url] = item.split('|').map(s => s.trim());
                    return { label, url };
                }));
            });

            // 2. NEW: Body-content parser (scans .resource-item-desc for links)
            const bodyParsers = document.querySelectorAll('.resource-item-footer[data-parse-body="true"]');
            bodyParsers.forEach(footer => {
                const card = footer.closest('.resource-item-card');
                const descContainer = card ? card.querySelector('.resource-item-desc') : null;
                if (!descContainer) return;

                // Find all links in the description
                const links = descContainer.querySelectorAll('a');
                const extractedItems = [];

                links.forEach(link => {
                    let label = link.textContent.trim();

                    // Specific handling for Ghost File Cards
                    const fileCard = link.closest('.kg-file-card');
                    if (fileCard) {
                        const titleEl = fileCard.querySelector('.kg-file-card-title');
                        if (titleEl) label = titleEl.textContent.trim();

                        // Move the label if it's still empty
                        if (!label && link.getAttribute('title')) {
                            label = link.getAttribute('title');
                        }

                        // Remove the whole card, not just the link
                        fileCard.remove();
                    } else {
                        // Regular link
                        link.remove();
                    }

                    if (label && link.href) {
                        extractedItems.push({ label, url: link.href });
                    }
                });

                if (extractedItems.length > 0) {
                    populateDropdown(footer, extractedItems);
                }
            });

            function populateDropdown(footer, items) {
                const menu = footer.querySelector('.dynamic-menu');
                const exploreBtn = footer.querySelector('.explore-btn');
                const downloadContainer = footer.querySelector('.dynamic-download-container');
                const card = footer.closest('.resource-item-card');
                const overlayLink = card ? card.querySelector('.overlay-download-link') : null;

                if (items.length > 0 && menu) {
                    items.forEach(item => {
                        if (item.label && item.url) {
                            const a = document.createElement('a');
                            a.href = item.url;
                            a.className = 'dropdown-item';
                            a.setAttribute('download', '');
                            a.textContent = item.label;
                            menu.appendChild(a);
                        }
                    });

                    // Toggle visibility
                    if (exploreBtn) exploreBtn.style.display = 'none';
                    if (downloadContainer) downloadContainer.style.display = 'block';
                    if (overlayLink) overlayLink.style.display = 'none';
                }
            }

            // Handle Dropdown Toggles for Dynamic Menus
            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.download-dropdown-btn');
                if (btn) {
                    const dropdown = btn.closest('.download-dropdown');
                    dropdown.classList.toggle('active');

                    // Close other dropdowns
                    document.querySelectorAll('.download-dropdown').forEach(d => {
                        if (d !== dropdown) d.classList.remove('active');
                    });

                    e.stopPropagation();
                } else {
                    document.querySelectorAll('.download-dropdown').forEach(d => {
                        d.classList.remove('active');
                    });
                }
            });
        });
    </script>

    {{ghost_foot}}

</body>

</html>